async Task ChangePageGrid_HR_ORG_Posts()
{
    int VisibleIndex = IndexGrid_HR_ORG_Posts;
    try
    {
    if (OpenDialogCodeHR_ORG_Posts == 1)
    {
        if (VisibleIndex != (Grid_HR_ORG_Posts.GetVisibleRowCount() - 1))
    { 
            Grid_HR_ORG_Posts.CancelEditAsync();
            IndexGrid_HR_ORG_Posts = VisibleIndex + 1;
    Grid_HR_ORG_Posts.StartEditRowAsync(IndexGrid_HR_ORG_Posts);
    }
    }
    else if (OpenDialogCodeHR_ORG_Posts == 0)
    {
        if (VisibleIndex != 0)
        {

            Grid_HR_ORG_Posts.CancelEditAsync();
            IndexGrid_HR_ORG_Posts = VisibleIndex - 1;
    Grid_HR_ORG_Posts.StartEditRowAsync(IndexGrid_HR_ORG_Posts);
    }

    }
    var e = (Entity.HR_ORG_Posts)Grid_HR_ORG_Posts.GetDataItem(IndexGrid_HR_ORG_Posts);
    JsonData = await Utility.JSON.ToJson(e);
    await Task.Delay(300);
    
    StateHasChanged();
    }
    catch (Exception ex)
    {

    Console.WriteLine("error in ChagePage" + ex.Message);
