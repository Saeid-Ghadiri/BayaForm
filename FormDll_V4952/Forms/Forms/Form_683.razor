async void OnYesButtonClickGrid_HR_ORG_Posts ()
{
       if (SelectedItemGrid_HR_ORG_Posts != null)
    {
      if (SelectedItemGrid_HR_ORG_Posts.Id == Guid.Empty)
      {
          var ListEntity = _Entity;
        ListEntity.Remove((Entity.HR_ORG_Posts)SelectedItemGrid_HR_ORG_Posts);
     
      }
      else
      {
        var cleanModel = new Entity.HR_ORG_Posts();
      // چک کن آیا پراپرتی IsDelete در این نوع وجود دارد؟
        var prop = typeof(Entity.HR_ORG_Posts).GetProperty("IsDelete");
        if (prop != null && prop.CanRead && prop.CanWrite)
        {
            // مقدار فعلی را بگیر
            var currentValue = prop.GetValue(SelectedItemGrid_HR_ORG_Posts);

            if (currentValue is bool boolValue)
            {
                // مقدار را معکوس کن
                var newValue = !boolValue;

                // روی هر دو شیء تنظیم کن
                prop.SetValue(SelectedItemGrid_HR_ORG_Posts, newValue);
                prop.SetValue(cleanModel, newValue);
