async void Dialog_Grid_HR_EMP_AcademicDocuments(int _OpenDialogCode, int VisibleIndex, GridEditFormTemplateContext e)
{
    OpenDialogCodeHR_EMP_AcademicDocuments = _OpenDialogCode;
    if (!CheckChangedData(await Utility.JSON.ToJson(e.EditModel)))
    {
    _ContextFormTemplateHR_EMP_AcademicDocuments = e;
    ConfirmationHR_EMP_AcademicDocuments = true;
    }
    else
    {
    await OnNoButtonHR_EMP_AcademicDocuments();
    }
}
async Task OnYesButtonHR_EMP_AcademicDocuments()
{

    ConfirmationHR_EMP_AcademicDocuments = false;
    await Task.Delay(1500);
    //bool FormValidate = await JSO.InvokeAsync<bool>("submitForm");
    bool FormValidate =  await JS.InvokeAsync<bool>("submitForm");
    if (FormValidate)
    {
        bool NotValid = false;
    var e = _ContextFormTemplateHR_EMP_AcademicDocuments.EditModel;
         //events
         

        if (!NotValid)
         {
        SaveGrid_HR_EMP_AcademicDocuments(_ContextFormTemplateHR_EMP_AcademicDocuments.DataItem, _ContextFormTemplateHR_EMP_AcademicDocuments.EditModel);
            await Grid_HR_EMP_AcademicDocuments.CancelEditAsync();
         await ChangePageGrid_HR_EMP_AcademicDocuments();
         await SetEditFormContextGrid_HR_EMP_AcademicDocuments();
         }
          
    }

}
async Task OnNoButtonHR_EMP_AcademicDocuments()
{
    ConfirmationHR_EMP_AcademicDocuments = false;
    await ChangePageGrid_HR_EMP_AcademicDocuments();
    await SetEditFormContextGrid_HR_EMP_AcademicDocuments();

}
async Task SetEditFormContextGrid_HR_EMP_AcademicDocuments()
{
    var e = (Entity.HR_EMP_AcademicDocuments)Grid_HR_EMP_AcademicDocuments.GetDataItem(IndexGrid_HR_EMP_AcademicDocuments);
    JsonData = await Utility.JSON.ToJson(e);
}

async Task ChangePageGrid_HR_EMP_AcademicDocuments()
{
    int VisibleIndex = IndexGrid_HR_EMP_AcademicDocuments;
    try
    {
    if (OpenDialogCodeHR_EMP_AcademicDocuments == 1)
    {
        if (VisibleIndex != (Grid_HR_EMP_AcademicDocuments.GetVisibleRowCount() - 1))
    { 
            Grid_HR_EMP_AcademicDocuments.CancelEditAsync();
            IndexGrid_HR_EMP_AcademicDocuments = VisibleIndex + 1;
    Grid_HR_EMP_AcademicDocuments.StartEditRowAsync(IndexGrid_HR_EMP_AcademicDocuments);
    }
    }
    else if (OpenDialogCodeHR_EMP_AcademicDocuments == 0)
    {
        if (VisibleIndex != 0)
        {

            Grid_HR_EMP_AcademicDocuments.CancelEditAsync();
            IndexGrid_HR_EMP_AcademicDocuments = VisibleIndex - 1;
    Grid_HR_EMP_AcademicDocuments.StartEditRowAsync(IndexGrid_HR_EMP_AcademicDocuments);
    }

    }
    var e = (Entity.HR_EMP_AcademicDocuments)Grid_HR_EMP_AcademicDocuments.GetDataItem(IndexGrid_HR_EMP_AcademicDocuments);
    JsonData = await Utility.JSON.ToJson(e);
    await Task.Delay(300);
    
    StateHasChanged();
    }
    catch (Exception ex)
    {

    Console.WriteLine("error in ChagePage" + ex.Message);
    }

}

