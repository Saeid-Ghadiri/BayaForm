    /// </summary>
    /// <returns></returns>
    public async Task setFocusOn()
    {
        if (!Grid_HR_EMP_AcademicDocuments.FocusedRowEnabled)
    {
            Grid_HR_EMP_AcademicDocuments.BeginUpdate();
    Grid_HR_EMP_AcademicDocuments.FocusedRowEnabled = true;

    Grid_HR_EMP_AcademicDocuments.EndUpdate();
    }

    }

    public async Task SelectRecord(int PageIndex, int __VisibleIndex)
    {

        isSending = true;
        await setFocusOn();
        PageIndexChanged(PageIndex);
        await ShowFormCU(Grid_HR_EMP_AcademicDocuments.GetDataItem(__VisibleIndex));
    DxPager.ActivePageIndex = PageIndex;
        Grid_HR_EMP_AcademicDocuments.BeginUpdate();
    Grid_HR_EMP_AcademicDocuments.PageIndex = PageIndex;
    Grid_HR_EMP_AcademicDocuments.EndUpdate();
    Grid_HR_EMP_AcademicDocuments.SetFocusedRowIndex(__VisibleIndex);

    isSending = false;
    }

