async void OnYesButtonClickGrid_HR_RMS_InterviewScores ()
{
       if (SelectedItemGrid_HR_RMS_InterviewScores != null)
    {
      if (SelectedItemGrid_HR_RMS_InterviewScores.Id == Guid.Empty)
      {
          var ListEntity = _Entity;
        ListEntity.Remove((Entity.HR_RMS_InterviewScores)SelectedItemGrid_HR_RMS_InterviewScores);
     
      }
      else
      {
        var cleanModel = new Entity.HR_RMS_InterviewScores();
      // چک کن آیا پراپرتی IsDelete در این نوع وجود دارد؟
        var prop = typeof(Entity.HR_RMS_InterviewScores).GetProperty("IsDelete");
        if (prop != null && prop.CanRead && prop.CanWrite)
        {
            // مقدار فعلی را بگیر
            var currentValue = prop.GetValue(SelectedItemGrid_HR_RMS_InterviewScores);

            if (currentValue is bool boolValue)
            {
                // مقدار را معکوس کن
                var newValue = !boolValue;

                // روی هر دو شیء تنظیم کن
                prop.SetValue(SelectedItemGrid_HR_RMS_InterviewScores, newValue);
                prop.SetValue(cleanModel, newValue);
            }
        }
        EntityHelper.SetPropertyValue(cleanModel, cleanModel._GetIdName, SelectedItemGrid_HR_RMS_InterviewScores._Id);
    
      await PostDataDelete(cleanModel); 
       
      }
    }
    var e= SelectedItemGrid_HR_RMS_InterviewScores;
    
    Grid_HR_RMS_InterviewScores.Reload();
    ConfirmationShownHR_RMS_InterviewScores = false;
     await Task.Yield();
    await InvokeAsync(StateHasChanged);

}
