async void OnYesButtonClickGrid_SCMPLATE_PurchaseStage ()
{
       if (SelectedItemGrid_SCMPLATE_PurchaseStage != null)
    {
      if (SelectedItemGrid_SCMPLATE_PurchaseStage.Id == Guid.Empty)
      {
          var ListEntity = _Entity;
        ListEntity.Remove((Entity.SCMPLATE_PurchaseStage)SelectedItemGrid_SCMPLATE_PurchaseStage);
     
      }
      else
      {
        var cleanModel = new Entity.SCMPLATE_PurchaseStage();
      // چک کن آیا پراپرتی IsDelete در این نوع وجود دارد؟
        var prop = typeof(Entity.SCMPLATE_PurchaseStage).GetProperty("IsDelete");
        if (prop != null && prop.CanRead && prop.CanWrite)
        {
            // مقدار فعلی را بگیر
            var currentValue = prop.GetValue(SelectedItemGrid_SCMPLATE_PurchaseStage);

            if (currentValue is bool boolValue)
            {
                // مقدار را معکوس کن
                var newValue = !boolValue;

                // روی هر دو شیء تنظیم کن
                prop.SetValue(SelectedItemGrid_SCMPLATE_PurchaseStage, newValue);
                prop.SetValue(cleanModel, newValue);
            }
        }
        EntityHelper.SetPropertyValue(cleanModel, cleanModel._GetIdName, SelectedItemGrid_SCMPLATE_PurchaseStage._Id);
    
      await PostDataDelete(cleanModel); 
       
      }
    }
    var e= SelectedItemGrid_SCMPLATE_PurchaseStage;
    
    Grid_SCMPLATE_PurchaseStage.Reload();
    ConfirmationShownSCMPLATE_PurchaseStage = false;
     await Task.Yield();
    await InvokeAsync(StateHasChanged);

}
