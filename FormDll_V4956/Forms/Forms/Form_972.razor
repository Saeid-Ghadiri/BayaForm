public void SaveGrid_SCM_ICT_Departments(object DataItem, object EditModel)
{
    var ListEntity = _Entity;
    var MainModel = (Entity.SCM_ICT_Departments)DataItem;
    if (MainModel != null)
    {
MainModel.Id = ((Entity.SCM_ICT_Departments)EditModel).Id;
MainModel.RequestID = ((Entity.SCM_ICT_Departments)EditModel).RequestID;
MainModel.CreateUser = ((Entity.SCM_ICT_Departments)EditModel).CreateUser;
MainModel.UpdateUser = ((Entity.SCM_ICT_Departments)EditModel).UpdateUser;
MainModel.CreateDate = ((Entity.SCM_ICT_Departments)EditModel).CreateDate;
MainModel.UpdateDate = ((Entity.SCM_ICT_Departments)EditModel).UpdateDate;
MainModel.IsDelete = ((Entity.SCM_ICT_Departments)EditModel).IsDelete;
MainModel.Code = ((Entity.SCM_ICT_Departments)EditModel).Code;
MainModel.Title = ((Entity.SCM_ICT_Departments)EditModel).Title;

    }
    else
    {
    ListEntity.Add((Entity.SCM_ICT_Departments)EditModel);
    }
}

