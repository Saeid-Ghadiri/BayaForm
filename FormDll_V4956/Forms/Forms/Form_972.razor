async void OnYesButtonClickGrid_SCM_ICT_Departments ()
{
       if (SelectedItemGrid_SCM_ICT_Departments != null)
    {
      if (SelectedItemGrid_SCM_ICT_Departments.Id == Guid.Empty)
      {
          var ListEntity = _Entity;
        ListEntity.Remove((Entity.SCM_ICT_Departments)SelectedItemGrid_SCM_ICT_Departments);
     
      }
      else
      {
        var cleanModel = new Entity.SCM_ICT_Departments();
      // چک کن آیا پراپرتی IsDelete در این نوع وجود دارد؟
        var prop = typeof(Entity.SCM_ICT_Departments).GetProperty("IsDelete");
        if (prop != null && prop.CanRead && prop.CanWrite)
        {
            // مقدار فعلی را بگیر
            var currentValue = prop.GetValue(SelectedItemGrid_SCM_ICT_Departments);

            if (currentValue is bool boolValue)
            {
                // مقدار را معکوس کن
                var newValue = !boolValue;

                // روی هر دو شیء تنظیم کن
                prop.SetValue(SelectedItemGrid_SCM_ICT_Departments, newValue);
                prop.SetValue(cleanModel, newValue);
            }
        }
        EntityHelper.SetPropertyValue(cleanModel, cleanModel._GetIdName, SelectedItemGrid_SCM_ICT_Departments._Id);
    
      await PostDataDelete(cleanModel); 
       
      }
    }
    var e= SelectedItemGrid_SCM_ICT_Departments;
    
    Grid_SCM_ICT_Departments.Reload();
    ConfirmationShownSCM_ICT_Departments = false;
     await Task.Yield();
    await InvokeAsync(StateHasChanged);

}
