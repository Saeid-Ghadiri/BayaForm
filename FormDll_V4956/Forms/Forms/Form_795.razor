async Task ChangePageGrid_HR_RMS_EducationalRecords()
{
    int VisibleIndex = IndexGrid_HR_RMS_EducationalRecords;
    try
    {
    if (OpenDialogCodeHR_RMS_EducationalRecords == 1)
    {
        if (VisibleIndex != (Grid_HR_RMS_EducationalRecords.GetVisibleRowCount() - 1))
    { 
            Grid_HR_RMS_EducationalRecords.CancelEditAsync();
            IndexGrid_HR_RMS_EducationalRecords = VisibleIndex + 1;
    Grid_HR_RMS_EducationalRecords.StartEditRowAsync(IndexGrid_HR_RMS_EducationalRecords);
    }
    }
    else if (OpenDialogCodeHR_RMS_EducationalRecords == 0)
    {
        if (VisibleIndex != 0)
        {

            Grid_HR_RMS_EducationalRecords.CancelEditAsync();
            IndexGrid_HR_RMS_EducationalRecords = VisibleIndex - 1;
    Grid_HR_RMS_EducationalRecords.StartEditRowAsync(IndexGrid_HR_RMS_EducationalRecords);
    }

    }
    var e = (Entity.HR_RMS_EducationalRecords)Grid_HR_RMS_EducationalRecords.GetDataItem(IndexGrid_HR_RMS_EducationalRecords);
    JsonData = await Utility.JSON.ToJson(e);
    await Task.Delay(300);
    
    StateHasChanged();
    }
    catch (Exception ex)
    {

    Console.WriteLine("error in ChagePage" + ex.Message);
    }

}

