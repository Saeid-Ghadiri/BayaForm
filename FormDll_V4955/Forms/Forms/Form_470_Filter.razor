<style>
    /* ************************************************** */
.detailArea form div:not(.devdrop) {
    margin-top: .1rem;
}

/* ************************************************** */
:root {
    --dark-blue: #0f172a;
    --purple: #6d28d9;
    --light-blue: #38bdf8;
    --accent-color: #818cf8;
    --text-color: #f8fafc;
}

.phonebook-header {
    background: linear-gradient(135deg, var(--dark-blue), var(--purple));
    color: var(--text-color);
    padding: 3rem 0;
    position: relative;
    overflow: hidden;
    border-radius: 10px 10px 10px 10px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
}

.blob-1,
.blob-2 {
    position: absolute;
    border-radius: 50%;
    background: rgba(129, 140, 248, 0.1);
    filter: blur(30px);
}

.blob-1 {
    width: 300px;
    height: 300px;
    top: -100px;
    left: -100px;
}

.blob-2 {
    width: 200px;
    height: 200px;
    bottom: -50px;
    right: -50px;
}

.header-content {
    text-align: right;
    padding: 1rem;
    position: relative;
    z-index: 2;
}

.icon-wrapper {
    width: 80px;
    height: 80px;
    background: linear-gradient(135deg, var(--light-blue), var(--accent-color));
    border-radius: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem;
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
}

.main-icon {
    font-size: 2.5rem;
    color: white;
}

.phonebook-header h1 {
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: 1rem;
    color: white;
}

.phonebook-header h1 span {
    color: var(--light-blue);
    position: relative;
}

.phonebook-header h1 span::after {
    content: '';
    position: absolute;
    bottom: -5px;
    right: 0;
    width: 100%;
    height: 3px;
    background: var(--light-blue);
    border-radius: 3px;
}

.tagline {
    font-size: 1.2rem;
    opacity: 0.9;
    color: rgba(248, 250, 252, 0.9);
    position: relative;
    padding-right: 1rem;
}

.tagline::before {
    content: '';
    position: absolute;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 5px;
    height: 20px;
    background: var(--accent-color);
    border-radius: 5px;
}

.header-image {
    text-align: center;
    position: relative;
}

.header-image img {
    max-height: 200px;
    width: auto;
    filter: drop-shadow(0 10px 20px rgba(0, 0, 0, 0.3));
    transition: transform 0.3s ease;
}

.header-image:hover img {
    transform: scale(1.05) rotate(-5deg);
}

/* انیمیشن‌ها */
.animate-float {
    animation: float 6s ease-in-out infinite;
}

.animate-slide {
    animation: slideIn 1s ease-out forwards;
    opacity: 0;
    transform: translateX(20px);
}

.delay-1 {
    animation-delay: 0.3s;
}

.animate-pop {
    animation: popIn 1s ease-out forwards;
    opacity: 0;
    transform: scale(0.8);
}

@@keyframes float {
    0% {
        transform: translateY(0px);
    }

    50% {
        transform: translateY(-15px);
    }

    100% {
        transform: translateY(0px);
    }
}

@@keyframes slideIn {
    to {
        opacity: 1;
        transform: translateX(0);
    }
}

@@keyframes popIn {
    to {
        opacity: 1;
        transform: scale(1);
    }
}

@@media (max-width: 992px) {
    .phonebook-header {
        padding: 2rem 0;
        border-radius: 0 0 20px 20px;
    }

    .header-content {
        text-align: center;
    }

    .icon-wrapper {
        margin: 0 auto 1.5rem;
    }

    .phonebook-header h1 {
        font-size: 2rem;
    }

    .tagline {
        font-size: 1rem;
        padding-right: 0;
        padding-left: 1rem;
    }

    .tagline::before {
        right: auto;
        left: 0;
    }

    .header-image img {
        max-height: 150px;
        margin-top: 1.5rem;
    }
}
</style>
