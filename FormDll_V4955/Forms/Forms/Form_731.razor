async void OnYesButtonClickGrid_SCMPLATE_ConsumableType ()
{
       if (SelectedItemGrid_SCMPLATE_ConsumableType != null)
    {
      if (SelectedItemGrid_SCMPLATE_ConsumableType.Id == Guid.Empty)
      {
          var ListEntity = _Entity;
        ListEntity.Remove((Entity.SCMPLATE_ConsumableType)SelectedItemGrid_SCMPLATE_ConsumableType);
     
      }
      else
      {
        var cleanModel = new Entity.SCMPLATE_ConsumableType();
      // چک کن آیا پراپرتی IsDelete در این نوع وجود دارد؟
        var prop = typeof(Entity.SCMPLATE_ConsumableType).GetProperty("IsDelete");
        if (prop != null && prop.CanRead && prop.CanWrite)
        {
            // مقدار فعلی را بگیر
            var currentValue = prop.GetValue(SelectedItemGrid_SCMPLATE_ConsumableType);

            if (currentValue is bool boolValue)
            {
                // مقدار را معکوس کن
                var newValue = !boolValue;

                // روی هر دو شیء تنظیم کن
                prop.SetValue(SelectedItemGrid_SCMPLATE_ConsumableType, newValue);
                prop.SetValue(cleanModel, newValue);
            }
        }
        EntityHelper.SetPropertyValue(cleanModel, cleanModel._GetIdName, SelectedItemGrid_SCMPLATE_ConsumableType._Id);
    
      await PostDataDelete(cleanModel); 
       
      }
    }
    var e= SelectedItemGrid_SCMPLATE_ConsumableType;
    
    Grid_SCMPLATE_ConsumableType.Reload();
    ConfirmationShownSCMPLATE_ConsumableType = false;
     await Task.Yield();
    await InvokeAsync(StateHasChanged);

}
