    public async Task setFocusOff()
    {
        //اگر فوکوس روشن بود خاموشش کن
        if (Grid_Shomaran_Annarr.FocusedRowEnabled)
    {
            //به علت یروزرسانی دیتاگرید و اینکه فوکوس باید مقدار اولیه داده شود از خط زیر استفاده می شود
            Grid_Shomaran_Annarr.BeginUpdate();
    Grid_Shomaran_Annarr.FocusedRowEnabled = false;
    Grid_Shomaran_Annarr.EndUpdate();
    }

    }
    /// <summary>
    /// فعال کردن فوکوس گرید
    /// </summary>
    /// <returns></returns>
    public async Task setFocusOn()
    {
        if (!Grid_Shomaran_Annarr.FocusedRowEnabled)
    {
            Grid_Shomaran_Annarr.BeginUpdate();
    Grid_Shomaran_Annarr.FocusedRowEnabled = true;

    Grid_Shomaran_Annarr.EndUpdate();
    }

    }

    public async Task SelectRecord(int PageIndex, int __VisibleIndex)
    {

        isSending = true;
        await setFocusOn();
        PageIndexChanged(PageIndex);
        await ShowFormCU(Grid_Shomaran_Annarr.GetDataItem(__VisibleIndex));
    DxPager.ActivePageIndex = PageIndex;
        Grid_Shomaran_Annarr.BeginUpdate();
    Grid_Shomaran_Annarr.PageIndex = PageIndex;
    Grid_Shomaran_Annarr.EndUpdate();
    Grid_Shomaran_Annarr.SetFocusedRowIndex(__VisibleIndex);

    isSending = false;
    }

    public async Task SetPageIndex(int Index)
    {
