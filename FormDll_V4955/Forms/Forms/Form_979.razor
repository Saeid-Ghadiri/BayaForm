async void OnYesButtonClickGrid_Shomaran_Annarr ()
{
       if (SelectedItemGrid_Shomaran_Annarr != null)
    {
      if (SelectedItemGrid_Shomaran_Annarr.Id == Guid.Empty)
      {
          var ListEntity = _Entity;
        ListEntity.Remove((Entity.Shomaran_Annarr)SelectedItemGrid_Shomaran_Annarr);
     
      }
      else
      {
        var cleanModel = new Entity.Shomaran_Annarr();
      // چک کن آیا پراپرتی IsDelete در این نوع وجود دارد؟
        var prop = typeof(Entity.Shomaran_Annarr).GetProperty("IsDelete");
        if (prop != null && prop.CanRead && prop.CanWrite)
        {
            // مقدار فعلی را بگیر
            var currentValue = prop.GetValue(SelectedItemGrid_Shomaran_Annarr);

            if (currentValue is bool boolValue)
            {
                // مقدار را معکوس کن
                var newValue = !boolValue;

                // روی هر دو شیء تنظیم کن
                prop.SetValue(SelectedItemGrid_Shomaran_Annarr, newValue);
                prop.SetValue(cleanModel, newValue);
            }
        }
        EntityHelper.SetPropertyValue(cleanModel, cleanModel._GetIdName, SelectedItemGrid_Shomaran_Annarr._Id);
    
      await PostDataDelete(cleanModel); 
       
      }
    }
    var e= SelectedItemGrid_Shomaran_Annarr;
    
    Grid_Shomaran_Annarr.Reload();
    ConfirmationShownShomaran_Annarr = false;
     await Task.Yield();
    await InvokeAsync(StateHasChanged);

}
