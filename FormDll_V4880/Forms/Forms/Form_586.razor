public void SaveGrid_Global_Vehicle(object DataItem, object EditModel)
{
    var ListEntity = _Entity;
    var MainModel = (Entity.Global_Vehicle)DataItem;
    if (MainModel != null)
    {
MainModel.Id = ((Entity.Global_Vehicle)EditModel).Id;
MainModel.RequestID = ((Entity.Global_Vehicle)EditModel).RequestID;
MainModel.CreateUser = ((Entity.Global_Vehicle)EditModel).CreateUser;
MainModel.UpdateUser = ((Entity.Global_Vehicle)EditModel).UpdateUser;
MainModel.CreateDate = ((Entity.Global_Vehicle)EditModel).CreateDate;
MainModel.UpdateDate = ((Entity.Global_Vehicle)EditModel).UpdateDate;
MainModel.IsDelete = ((Entity.Global_Vehicle)EditModel).IsDelete;
MainModel.Title = ((Entity.Global_Vehicle)EditModel).Title;

    }
    else
    {
    ListEntity.Add((Entity.Global_Vehicle)EditModel);
    }
}

