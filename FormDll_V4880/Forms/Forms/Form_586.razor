async Task SetEditFormContextGrid_Global_Vehicle()
{
    var e = (Entity.Global_Vehicle)Grid_Global_Vehicle.GetDataItem(IndexGrid_Global_Vehicle);
    JsonData = await Utility.JSON.ToJson(e);
}

async Task ChangePageGrid_Global_Vehicle()
{
    int VisibleIndex = IndexGrid_Global_Vehicle;
    try
    {
    if (OpenDialogCodeGlobal_Vehicle == 1)
    {
        if (VisibleIndex != (Grid_Global_Vehicle.GetVisibleRowCount() - 1))
    { 
            Grid_Global_Vehicle.CancelEditAsync();
            IndexGrid_Global_Vehicle = VisibleIndex + 1;
    Grid_Global_Vehicle.StartEditRowAsync(IndexGrid_Global_Vehicle);
    }
    }
    else if (OpenDialogCodeGlobal_Vehicle == 0)
    {
        if (VisibleIndex != 0)
        {

            Grid_Global_Vehicle.CancelEditAsync();
            IndexGrid_Global_Vehicle = VisibleIndex - 1;
    Grid_Global_Vehicle.StartEditRowAsync(IndexGrid_Global_Vehicle);
    }

    }
    var e = (Entity.Global_Vehicle)Grid_Global_Vehicle.GetDataItem(IndexGrid_Global_Vehicle);
    JsonData = await Utility.JSON.ToJson(e);
    await Task.Delay(300);
    
    StateHasChanged();
    }
    catch (Exception ex)
    {

    Console.WriteLine("error in ChagePage" + ex.Message);
    }

}

