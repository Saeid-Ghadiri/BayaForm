async void OnDeleteButtonClickGrid_Global_Vehicle (GridCommandColumnCellDisplayTemplateContext ex)
{
    SelectedItemGrid_Global_Vehicle = (ex.DataItem as Entity.Global_Vehicle);
    var e =SelectedItemGrid_Global_Vehicle;
    
     
    Console.WriteLine("end OnDeleteButtonClickGrid_test_OrderBody 0");
    ConfirmationShownGlobal_Vehicle = true;
    await Task.Yield();
     await InvokeAsync(StateHasChanged);
    
    Console.WriteLine("end OnDeleteButtonClickGrid_test_OrderBody 1");
}
async void OnYesButtonClickGrid_Global_Vehicle ()
{
       if (SelectedItemGrid_Global_Vehicle != null)
    {
      if (SelectedItemGrid_Global_Vehicle.Id == Guid.Empty)
      {
          var ListEntity = _Entity;
        ListEntity.Remove((Entity.Global_Vehicle)SelectedItemGrid_Global_Vehicle);
     
      }
      else
      {
        var cleanModel = new Entity.Global_Vehicle();
      // چک کن آیا پراپرتی IsDelete در این نوع وجود دارد؟
        var prop = typeof(Entity.Global_Vehicle).GetProperty("IsDelete");
        if (prop != null && prop.CanRead && prop.CanWrite)
        {
            // مقدار فعلی را بگیر
            var currentValue = prop.GetValue(SelectedItemGrid_Global_Vehicle);

            if (currentValue is bool boolValue)
            {
                // مقدار را معکوس کن
                var newValue = !boolValue;

                // روی هر دو شیء تنظیم کن
                prop.SetValue(SelectedItemGrid_Global_Vehicle, newValue);
                prop.SetValue(cleanModel, newValue);
            }
        }
        EntityHelper.SetPropertyValue(cleanModel, cleanModel._GetIdName, SelectedItemGrid_Global_Vehicle._Id);
    
      await PostDataDelete(cleanModel); 
       
      }
    }
    var e= SelectedItemGrid_Global_Vehicle;
    
    Grid_Global_Vehicle.Reload();
    ConfirmationShownGlobal_Vehicle = false;
     await Task.Yield();
    await InvokeAsync(StateHasChanged);

}
void OnNoButtonClickGrid_Global_Vehicle ()
{
    ConfirmationShownGlobal_Vehicle = false;
}

