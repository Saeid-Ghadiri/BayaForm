async void OnYesButtonClickGrid_HR_Base_TransportServiceType ()
{
       if (SelectedItemGrid_HR_Base_TransportServiceType != null)
    {
      if (SelectedItemGrid_HR_Base_TransportServiceType.Id == Guid.Empty)
      {
          var ListEntity = _Entity;
        ListEntity.Remove((Entity.HR_Base_TransportServiceType)SelectedItemGrid_HR_Base_TransportServiceType);
     
      }
      else
      {
        var cleanModel = new Entity.HR_Base_TransportServiceType();
      // چک کن آیا پراپرتی IsDelete در این نوع وجود دارد؟
        var prop = typeof(Entity.HR_Base_TransportServiceType).GetProperty("IsDelete");
        if (prop != null && prop.CanRead && prop.CanWrite)
        {
            // مقدار فعلی را بگیر
            var currentValue = prop.GetValue(SelectedItemGrid_HR_Base_TransportServiceType);

            if (currentValue is bool boolValue)
            {
                // مقدار را معکوس کن
                var newValue = !boolValue;

                // روی هر دو شیء تنظیم کن
                prop.SetValue(SelectedItemGrid_HR_Base_TransportServiceType, newValue);
                prop.SetValue(cleanModel, newValue);
            }
        }
        EntityHelper.SetPropertyValue(cleanModel, cleanModel._GetIdName, SelectedItemGrid_HR_Base_TransportServiceType._Id);
    
      await PostDataDelete(cleanModel); 
       
      }
    }
    var e= SelectedItemGrid_HR_Base_TransportServiceType;
    
    Grid_HR_Base_TransportServiceType.Reload();
    ConfirmationShownHR_Base_TransportServiceType = false;
     await Task.Yield();
    await InvokeAsync(StateHasChanged);

}
