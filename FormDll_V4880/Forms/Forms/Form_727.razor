        isSending = true;
        await setFocusOn();
        PageIndexChanged(PageIndex);
        await ShowFormCU(Grid_HR_Base_TransportServiceType.GetDataItem(__VisibleIndex));
    DxPager.ActivePageIndex = PageIndex;
        Grid_HR_Base_TransportServiceType.BeginUpdate();
    Grid_HR_Base_TransportServiceType.PageIndex = PageIndex;
    Grid_HR_Base_TransportServiceType.EndUpdate();
    Grid_HR_Base_TransportServiceType.SetFocusedRowIndex(__VisibleIndex);

    isSending = false;
    }

