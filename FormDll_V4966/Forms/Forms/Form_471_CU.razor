        TablePost = await Utility.JSON.ToObject<Table>("{\"Name\":\"Global_PHB_Main\",\"GetNameAs\":\"Global_PHB_Main\",\"Column\":[{\"Name\":\"Id\",\"GetNameAs\":\"Id\"},{\"Name\":\"RequestID\",\"GetNameAs\":\"RequestID\"},{\"Name\":\"CreateUser\",\"GetNameAs\":\"CreateUser\"},{\"Name\":\"UpdateUser\",\"GetNameAs\":\"UpdateUser\"},{\"Name\":\"CreateDate\",\"GetNameAs\":\"CreateDate\"},{\"Name\":\"UpdateDate\",\"GetNameAs\":\"UpdateDate\"},{\"Name\":\"IsDelete\",\"GetNameAs\":\"IsDelete\"},{\"Name\":\"CompanyName\",\"GetNameAs\":\"CompanyName\"},{\"Name\":\"UnitName\",\"GetNameAs\":\"UnitName\"},{\"Name\":\"SectionName\",\"GetNameAs\":\"SectionName\"},{\"Name\":\"UserFullName\",\"GetNameAs\":\"UserFullName\"},{\"Name\":\"InternalCodeTel\",\"GetNameAs\":\"InternalCodeTel\"},{\"Name\":\"MobCell\",\"GetNameAs\":\"MobCell\"},{\"Name\":\"Email\",\"GetNameAs\":\"Email\"},{\"Name\":\"InternalCodeTe2\",\"GetNameAs\":\"InternalCodeTe2\"},{\"Name\":\"InternalCodeTel3\",\"GetNameAs\":\"InternalCodeTel3\"},{\"Name\":\"InternalCodeTel4\",\"GetNameAs\":\"InternalCodeTel4\"},{\"Name\":\"User_EMP_NO\",\"GetNameAs\":\"User_EMP_NO\"}],\"Relation\":[]}");

