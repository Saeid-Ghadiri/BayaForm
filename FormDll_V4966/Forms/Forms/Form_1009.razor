async void OnYesButtonClickGrid_IDMS_ResultingFrom ()
{
       if (SelectedItemGrid_IDMS_ResultingFrom != null)
    {
      if (SelectedItemGrid_IDMS_ResultingFrom.Id == Guid.Empty)
      {
          var ListEntity = _Entity;
        ListEntity.Remove((Entity.IDMS_ResultingFrom)SelectedItemGrid_IDMS_ResultingFrom);
     
      }
      else
      {
        var cleanModel = new Entity.IDMS_ResultingFrom();
      // چک کن آیا پراپرتی IsDelete در این نوع وجود دارد؟
        var prop = typeof(Entity.IDMS_ResultingFrom).GetProperty("IsDelete");
        if (prop != null && prop.CanRead && prop.CanWrite)
        {
            // مقدار فعلی را بگیر
            var currentValue = prop.GetValue(SelectedItemGrid_IDMS_ResultingFrom);

            if (currentValue is bool boolValue)
            {
                // مقدار را معکوس کن
                var newValue = !boolValue;

                // روی هر دو شیء تنظیم کن
                prop.SetValue(SelectedItemGrid_IDMS_ResultingFrom, newValue);
                prop.SetValue(cleanModel, newValue);
            }
        }
        EntityHelper.SetPropertyValue(cleanModel, cleanModel._GetIdName, SelectedItemGrid_IDMS_ResultingFrom._Id);
    
      await PostDataDelete(cleanModel); 
       
      }
    }
    var e= SelectedItemGrid_IDMS_ResultingFrom;
    
    Grid_IDMS_ResultingFrom.Reload();
    ConfirmationShownIDMS_ResultingFrom = false;
     await Task.Yield();
    await InvokeAsync(StateHasChanged);

}
void OnNoButtonClickGrid_IDMS_ResultingFrom ()
{
    ConfirmationShownIDMS_ResultingFrom = false;
}

