public void SaveGrid_IDMS_ResultingFrom(object DataItem, object EditModel)
{
    var ListEntity = _Entity;
    var MainModel = (Entity.IDMS_ResultingFrom)DataItem;
    if (MainModel != null)
    {
MainModel.Id = ((Entity.IDMS_ResultingFrom)EditModel).Id;
MainModel.RequestID = ((Entity.IDMS_ResultingFrom)EditModel).RequestID;
MainModel.CreateUser = ((Entity.IDMS_ResultingFrom)EditModel).CreateUser;
MainModel.UpdateUser = ((Entity.IDMS_ResultingFrom)EditModel).UpdateUser;
MainModel.CreateDate = ((Entity.IDMS_ResultingFrom)EditModel).CreateDate;
MainModel.UpdateDate = ((Entity.IDMS_ResultingFrom)EditModel).UpdateDate;
MainModel.IsDelete = ((Entity.IDMS_ResultingFrom)EditModel).IsDelete;
MainModel.ResultingFromCode = ((Entity.IDMS_ResultingFrom)EditModel).ResultingFromCode;
MainModel.ResultingFromTitle = ((Entity.IDMS_ResultingFrom)EditModel).ResultingFromTitle;

    }
    else
    {
    ListEntity.Add((Entity.IDMS_ResultingFrom)EditModel);
    }
}

