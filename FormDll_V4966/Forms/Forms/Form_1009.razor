async Task ChangePageGrid_IDMS_ResultingFrom()
{
    int VisibleIndex = IndexGrid_IDMS_ResultingFrom;
    try
    {
    if (OpenDialogCodeIDMS_ResultingFrom == 1)
    {
        if (VisibleIndex != (Grid_IDMS_ResultingFrom.GetVisibleRowCount() - 1))
    { 
            Grid_IDMS_ResultingFrom.CancelEditAsync();
            IndexGrid_IDMS_ResultingFrom = VisibleIndex + 1;
    Grid_IDMS_ResultingFrom.StartEditRowAsync(IndexGrid_IDMS_ResultingFrom);
    }
    }
    else if (OpenDialogCodeIDMS_ResultingFrom == 0)
    {
        if (VisibleIndex != 0)
        {

            Grid_IDMS_ResultingFrom.CancelEditAsync();
            IndexGrid_IDMS_ResultingFrom = VisibleIndex - 1;
    Grid_IDMS_ResultingFrom.StartEditRowAsync(IndexGrid_IDMS_ResultingFrom);
    }

    }
    var e = (Entity.IDMS_ResultingFrom)Grid_IDMS_ResultingFrom.GetDataItem(IndexGrid_IDMS_ResultingFrom);
    JsonData = await Utility.JSON.ToJson(e);
    await Task.Delay(300);
    
    StateHasChanged();
    }
    catch (Exception ex)
    {

    Console.WriteLine("error in ChagePage" + ex.Message);
    }

}

