async void OnYesButtonClickGrid_HR_JobIntervieweTitle ()
{
       if (SelectedItemGrid_HR_JobIntervieweTitle != null)
    {
      if (SelectedItemGrid_HR_JobIntervieweTitle.Id == Guid.Empty)
      {
          var ListEntity = _Entity;
        ListEntity.Remove((Entity.HR_JobIntervieweTitle)SelectedItemGrid_HR_JobIntervieweTitle);
     
      }
      else
      {
        var cleanModel = new Entity.HR_JobIntervieweTitle();
      // چک کن آیا پراپرتی IsDelete در این نوع وجود دارد؟
        var prop = typeof(Entity.HR_JobIntervieweTitle).GetProperty("IsDelete");
        if (prop != null && prop.CanRead && prop.CanWrite)
        {
            // مقدار فعلی را بگیر
            var currentValue = prop.GetValue(SelectedItemGrid_HR_JobIntervieweTitle);

            if (currentValue is bool boolValue)
            {
                // مقدار را معکوس کن
                var newValue = !boolValue;

                // روی هر دو شیء تنظیم کن
                prop.SetValue(SelectedItemGrid_HR_JobIntervieweTitle, newValue);
                prop.SetValue(cleanModel, newValue);
            }
        }
        EntityHelper.SetPropertyValue(cleanModel, cleanModel._GetIdName, SelectedItemGrid_HR_JobIntervieweTitle._Id);
    
      await PostDataDelete(cleanModel); 
       
      }
    }
    var e= SelectedItemGrid_HR_JobIntervieweTitle;
    
    Grid_HR_JobIntervieweTitle.Reload();
    ConfirmationShownHR_JobIntervieweTitle = false;
     await Task.Yield();
    await InvokeAsync(StateHasChanged);

