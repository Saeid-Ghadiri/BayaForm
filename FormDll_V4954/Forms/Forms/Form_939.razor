    public async Task setFocusOn()
    {
        if (!Grid_HR_JobIntervieweTitle.FocusedRowEnabled)
    {
            Grid_HR_JobIntervieweTitle.BeginUpdate();
    Grid_HR_JobIntervieweTitle.FocusedRowEnabled = true;

    Grid_HR_JobIntervieweTitle.EndUpdate();
    }

    }

    public async Task SelectRecord(int PageIndex, int __VisibleIndex)
    {

        isSending = true;
        await setFocusOn();
        PageIndexChanged(PageIndex);
        await ShowFormCU(Grid_HR_JobIntervieweTitle.GetDataItem(__VisibleIndex));
    DxPager.ActivePageIndex = PageIndex;
        Grid_HR_JobIntervieweTitle.BeginUpdate();
    Grid_HR_JobIntervieweTitle.PageIndex = PageIndex;
    Grid_HR_JobIntervieweTitle.EndUpdate();
    Grid_HR_JobIntervieweTitle.SetFocusedRowIndex(__VisibleIndex);

    isSending = false;
    }

