async void OnDeleteButtonClickGrid_FU_FU_Main (GridCommandColumnCellDisplayTemplateContext ex)
{
    SelectedItemGrid_FU_FU_Main = (ex.DataItem as Entity.FU_FU_Main);
    var e =SelectedItemGrid_FU_FU_Main;
    
     
    Console.WriteLine("end OnDeleteButtonClickGrid_test_OrderBody 0");
    ConfirmationShownFU_FU_Main = true;
    await Task.Yield();
     await InvokeAsync(StateHasChanged);
    
    Console.WriteLine("end OnDeleteButtonClickGrid_test_OrderBody 1");
}
async void OnYesButtonClickGrid_FU_FU_Main ()
{
       if (SelectedItemGrid_FU_FU_Main != null)
    {
      if (SelectedItemGrid_FU_FU_Main.Id == Guid.Empty)
      {
          var ListEntity = _Entity;
        ListEntity.Remove((Entity.FU_FU_Main)SelectedItemGrid_FU_FU_Main);
     
      }
      else
      {
        var cleanModel = new Entity.FU_FU_Main();
      // چک کن آیا پراپرتی IsDelete در این نوع وجود دارد؟
        var prop = typeof(Entity.FU_FU_Main).GetProperty("IsDelete");
        if (prop != null && prop.CanRead && prop.CanWrite)
        {
            // مقدار فعلی را بگیر
            var currentValue = prop.GetValue(SelectedItemGrid_FU_FU_Main);

            if (currentValue is bool boolValue)
            {
                // مقدار را معکوس کن
                var newValue = !boolValue;

                // روی هر دو شیء تنظیم کن
                prop.SetValue(SelectedItemGrid_FU_FU_Main, newValue);
                prop.SetValue(cleanModel, newValue);
            }
        }
        EntityHelper.SetPropertyValue(cleanModel, cleanModel._GetIdName, SelectedItemGrid_FU_FU_Main._Id);
    
      await PostDataDelete(cleanModel); 
       
      }
    }
    var e= SelectedItemGrid_FU_FU_Main;
    
    Grid_FU_FU_Main.Reload();
    ConfirmationShownFU_FU_Main = false;
     await Task.Yield();
    await InvokeAsync(StateHasChanged);

}
void OnNoButtonClickGrid_FU_FU_Main ()
{
    ConfirmationShownFU_FU_Main = false;
}

