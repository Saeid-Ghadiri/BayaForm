public void SaveGrid_FU_FU_Main(object DataItem, object EditModel)
{
    var ListEntity = _Entity;
    var MainModel = (Entity.FU_FU_Main)DataItem;
    if (MainModel != null)
    {
MainModel.Id = ((Entity.FU_FU_Main)EditModel).Id;
MainModel.RequestID = ((Entity.FU_FU_Main)EditModel).RequestID;
MainModel.CreateUser = ((Entity.FU_FU_Main)EditModel).CreateUser;
MainModel.UpdateUser = ((Entity.FU_FU_Main)EditModel).UpdateUser;
MainModel.CreateDate = ((Entity.FU_FU_Main)EditModel).CreateDate;
MainModel.UpdateDate = ((Entity.FU_FU_Main)EditModel).UpdateDate;
MainModel.IsDelete = ((Entity.FU_FU_Main)EditModel).IsDelete;
MainModel.SystemCreatedUser = ((Entity.FU_FU_Main)EditModel).SystemCreatedUser;

    }
    else
    {
    ListEntity.Add((Entity.FU_FU_Main)EditModel);
    }
}

