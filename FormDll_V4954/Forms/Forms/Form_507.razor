}

async Task ChangePageGrid_FU_FU_Main()
{
    int VisibleIndex = IndexGrid_FU_FU_Main;
    try
    {
    if (OpenDialogCodeFU_FU_Main == 1)
    {
        if (VisibleIndex != (Grid_FU_FU_Main.GetVisibleRowCount() - 1))
    { 
            Grid_FU_FU_Main.CancelEditAsync();
            IndexGrid_FU_FU_Main = VisibleIndex + 1;
    Grid_FU_FU_Main.StartEditRowAsync(IndexGrid_FU_FU_Main);
    }
    }
    else if (OpenDialogCodeFU_FU_Main == 0)
    {
        if (VisibleIndex != 0)
        {

            Grid_FU_FU_Main.CancelEditAsync();
            IndexGrid_FU_FU_Main = VisibleIndex - 1;
    Grid_FU_FU_Main.StartEditRowAsync(IndexGrid_FU_FU_Main);
    }

    }
    var e = (Entity.FU_FU_Main)Grid_FU_FU_Main.GetDataItem(IndexGrid_FU_FU_Main);
    JsonData = await Utility.JSON.ToJson(e);
    await Task.Delay(300);
    
    StateHasChanged();
    }
    catch (Exception ex)
    {

    Console.WriteLine("error in ChagePage" + ex.Message);
    }

}

