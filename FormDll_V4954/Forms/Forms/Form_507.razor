    {
    var item = ((Entity.FU_FU_Main)e.Grid.GetDataItem(e.VisibleIndex));

       if (item.IsDelete == true)
       {
           e.CssClass = "bg-lightred disablediv";
       }
    }
}

async void CustomizeEditGrid_FU_FU_Main(GridCustomizeEditModelEventArgs e)
{

    if (e.IsNew)
    {

    var newRow = (Entity.FU_FU_Main)e.EditModel;

      newRow.SystemCreatedUser = _RequestParameters.UserStarterFullName;


    }

await ShowFormCU(e);
}
