MainModel.CreateUser = ((Entity.SCM_OS_JobTitle)EditModel).CreateUser;
MainModel.UpdateUser = ((Entity.SCM_OS_JobTitle)EditModel).UpdateUser;
MainModel.CreateDate = ((Entity.SCM_OS_JobTitle)EditModel).CreateDate;
MainModel.UpdateDate = ((Entity.SCM_OS_JobTitle)EditModel).UpdateDate;
MainModel.IsDelete = ((Entity.SCM_OS_JobTitle)EditModel).IsDelete;
MainModel.Title = ((Entity.SCM_OS_JobTitle)EditModel).Title;

    }
    else
    {
    ListEntity.Add((Entity.SCM_OS_JobTitle)EditModel);
    }
}

