async void OnYesButtonClickGrid_SCM_OS_JobTitle ()
{
       if (SelectedItemGrid_SCM_OS_JobTitle != null)
    {
      if (SelectedItemGrid_SCM_OS_JobTitle.Id == Guid.Empty)
      {
          var ListEntity = _Entity;
        ListEntity.Remove((Entity.SCM_OS_JobTitle)SelectedItemGrid_SCM_OS_JobTitle);
     
      }
      else
      {
        var cleanModel = new Entity.SCM_OS_JobTitle();
      // چک کن آیا پراپرتی IsDelete در این نوع وجود دارد؟
        var prop = typeof(Entity.SCM_OS_JobTitle).GetProperty("IsDelete");
        if (prop != null && prop.CanRead && prop.CanWrite)
        {
            // مقدار فعلی را بگیر
            var currentValue = prop.GetValue(SelectedItemGrid_SCM_OS_JobTitle);

            if (currentValue is bool boolValue)
            {
                // مقدار را معکوس کن
                var newValue = !boolValue;

                // روی هر دو شیء تنظیم کن
                prop.SetValue(SelectedItemGrid_SCM_OS_JobTitle, newValue);
                prop.SetValue(cleanModel, newValue);
            }
        }
        EntityHelper.SetPropertyValue(cleanModel, cleanModel._GetIdName, SelectedItemGrid_SCM_OS_JobTitle._Id);
    
      await PostDataDelete(cleanModel); 
       
      }
    }
    var e= SelectedItemGrid_SCM_OS_JobTitle;
    
    Grid_SCM_OS_JobTitle.Reload();
    ConfirmationShownSCM_OS_JobTitle = false;
     await Task.Yield();
    await InvokeAsync(StateHasChanged);

}
