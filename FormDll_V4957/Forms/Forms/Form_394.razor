async void Dialog_Grid_SCM_ProductRequestDetails(int _OpenDialogCode, int VisibleIndex, GridEditFormTemplateContext e)
{
    OpenDialogCodeSCM_ProductRequestDetails = _OpenDialogCode;
    if (!CheckChangedData(await Utility.JSON.ToJson(e.EditModel)))
    {
    _ContextFormTemplateSCM_ProductRequestDetails = e;
    ConfirmationSCM_ProductRequestDetails = true;
    }
    else
    {
    await OnNoButtonSCM_ProductRequestDetails();
    }
}
async Task OnYesButtonSCM_ProductRequestDetails()
{

    ConfirmationSCM_ProductRequestDetails = false;
    await Task.Delay(1500);
    //bool FormValidate = await JSO.InvokeAsync<bool>("submitForm");
    bool FormValidate =  await JS.InvokeAsync<bool>("submitForm");
    if (FormValidate)
    {
        bool NotValid = false;
    var e = _ContextFormTemplateSCM_ProductRequestDetails.EditModel;
         //events
         

        if (!NotValid)
         {
        SaveGrid_SCM_ProductRequestDetails(_ContextFormTemplateSCM_ProductRequestDetails.DataItem, _ContextFormTemplateSCM_ProductRequestDetails.EditModel);
            await Grid_SCM_ProductRequestDetails.CancelEditAsync();
         await ChangePageGrid_SCM_ProductRequestDetails();
         await SetEditFormContextGrid_SCM_ProductRequestDetails();
         }
          
    }

}
async Task OnNoButtonSCM_ProductRequestDetails()
{
    ConfirmationSCM_ProductRequestDetails = false;
    await ChangePageGrid_SCM_ProductRequestDetails();
    await SetEditFormContextGrid_SCM_ProductRequestDetails();

}
async Task SetEditFormContextGrid_SCM_ProductRequestDetails()
{
    var e = (Entity.SCM_ProductRequestDetails)Grid_SCM_ProductRequestDetails.GetDataItem(IndexGrid_SCM_ProductRequestDetails);
    JsonData = await Utility.JSON.ToJson(e);
}

async Task ChangePageGrid_SCM_ProductRequestDetails()
{
    int VisibleIndex = IndexGrid_SCM_ProductRequestDetails;
    try
    {
    if (OpenDialogCodeSCM_ProductRequestDetails == 1)
    {
        if (VisibleIndex != (Grid_SCM_ProductRequestDetails.GetVisibleRowCount() - 1))
    { 
            Grid_SCM_ProductRequestDetails.CancelEditAsync();
            IndexGrid_SCM_ProductRequestDetails = VisibleIndex + 1;
    Grid_SCM_ProductRequestDetails.StartEditRowAsync(IndexGrid_SCM_ProductRequestDetails);
    }
    }
    else if (OpenDialogCodeSCM_ProductRequestDetails == 0)
    {
        if (VisibleIndex != 0)
        {

            Grid_SCM_ProductRequestDetails.CancelEditAsync();
            IndexGrid_SCM_ProductRequestDetails = VisibleIndex - 1;
    Grid_SCM_ProductRequestDetails.StartEditRowAsync(IndexGrid_SCM_ProductRequestDetails);
    }

    }
    var e = (Entity.SCM_ProductRequestDetails)Grid_SCM_ProductRequestDetails.GetDataItem(IndexGrid_SCM_ProductRequestDetails);
    JsonData = await Utility.JSON.ToJson(e);
    await Task.Delay(300);
    
    StateHasChanged();
    }
    catch (Exception ex)
    {

    Console.WriteLine("error in ChagePage" + ex.Message);
    }

}

