@using Baya.Models.ViewEngine
@using Domain.Utility
@using Newtonsoft.Json
@using Newtonsoft.Json.Linq
@using Microsoft.JSInterop;  
@namespace DrowpDownPage
@using Castle.DynamicLinqQueryBuilder;

<div id=@(Id) class="dropdown devdrop @(_Visible?"":"d-none") @CssClass">
@if (!string.IsNullOrEmpty(Label) && _Visible)
{
    <label id=@(Id + "label")>
        @Label
        @if (Required.HasValue && Required == true)
        {
            <span class="text-danger" id=@(Id + "label")>*</span>
        }
        @if (!string.IsNullOrEmpty(ToolTip))
        {
            <i class="bi bi-question-circle text-muted" data-bs-toggle="tooltip" data-bs-title="@ToolTip" title="@ToolTip"></i>
        }
    </label>
}

    
    <input id=@(Id + "Input") type="hidden" value="@Value"/>
    @if (DisplayFormat is null || DisplayFormat == "DropDown")
    {
        @if(DropdownSelected!="انتخاب کنید"){
            <span @onclick="ResetDropdown" class="bi bi-x btnclearDP"></span>
        }
        
        <button id=@(Id + "Button")  type="button" hidden="@((TextGrid))" class="form-select dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false" data-bs-auto-close="outside" @attributes=@_Attributes>
            @DropdownSelected
        </button>
        <label hidden="@((!TextGrid))">@DropdownSelected</label>
        <div id=@(Id + "DivDataGrid") class="dropdown-menu p-2">
            <DataGrid Id="@Id"   @ref=RefDataGrid OnItemSelected="ItemSelected" Component="Component" _Entity=__Entity _EntityRow=_EntityRow></DataGrid>

        </div>
    }
    else
    {
        
        <DataGrid   @ref=RefDataGrid OnItemSelected="ItemSelected" Component="Component" _Entity=__Entity _EntityRow=_EntityRow></DataGrid>

    
    }
    

</div>


@code {
