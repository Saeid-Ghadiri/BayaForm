    protected override async Task OnInitializedAsync()
    {
     Console.WriteLine(Label + " " + Value?.ToString());
        DropdownSelected = "انتخاب کنید";
        //ست نمودن اولیه مقدار داخل دراپ دان
        if (!NotMapped)
        {
            if (!ExternalApi)
            {
                if (!string.IsNullOrEmpty(Text))
                {
                   if (!string.IsNullOrEmpty(Text.Trim()))
                      DropdownSelected = Text;
                }
                // اگر در حالت TextGrid هستیم و Value داریم و URL موجود است، داده را لود کن
                if (TextGrid && Value != null && Component?.data?.url != null)
                {
                    await LoadData(Value.ToString());
                }

            }
            else
            {
                if (Value != null)
                {
                    await LoadData(Value.ToString());
                }
            }
            StateHasChanged();

        }
        ///افزودن اتربیوت های دریافتی به کامپوننت
        if (Attributes.Keys.Count > 0)
        {
            foreach (var item in Attributes)
            {
                _Attributes.Add(item.Key, item.Value);
            }
        }
    //Set Model First 
     __Entity = _Entity;
        //اجرای دیسبل
        _Disabled = Disabled;
        RunDisabled();
        _Visible = Visible;
    }
    /// <summary>
    /// اگر کامپوننت دیسبل بود اتربیوت دسیبل پاس داده شود
    /// </summary>
    protected void RunDisabled()
    {
        if (_Disabled)
        {
            AddAttribute("disabled", "true");
            RemoveAttribute("Required");
        }
        else
        {
            RemoveAttribute("disabled");
            if (Required.HasValue && Required.Value)
            {
                AddAttribute("Required", "Required");
            }
        }
        Disabled = _Disabled;
    }
    #endregion



    #region StartUp
    protected override async Task OnParametersSetAsync()
    {
        //اگر مقدار ولیو تغییر کرده بود
        //اگر از نوع تیتر گرید بود
        //اگر از نوع خارجی بود یا داخل گرید است
        if ((_value != Value) && (TextGrid) && (Value != null) && (Component?.data?.url != null))
        {
            _value = Value;
            await LoadData(Value.ToString()); 
        }

        RunDisabled();
        Visible = _Visible;
    }

    #endregion



    #region Classes
    //// <summary>
    /// نمایش داخل دراپ دان در صورت انتخاب
    /// </summary>
    /// <param name="Item"></param>
    /// <returns></returns>
    public async Task ItemSelected(object Item)
    {
        DropdownSelected = "";
        string item_ = "";
        Guid Value_ = new Guid();
        var json = Newtonsoft.Json.JsonConvert.SerializeObject(Item);
        JObject  data = JObject.Parse(json);
        // SItem = data;
        List<KeyValuePair<string, string>> list = await ConvertParameter.GetTemplate(Component.template);
         Value =!string.IsNullOrEmpty(Component.valueProperty) ?
             data[Component?.valueProperty] ?? null : null;
        for (int i = 0; i < list.Count; i++)
        {
            item_ = list[i].Key;
            if (i == 0)
            {
                DropdownSelected += data[item_];
            }
            else
            {
                DropdownSelected += " " + data[item_];
            }
        } 
        if (NotMapped)
        {
            Value = DropdownSelected;
        }
        if (string.IsNullOrEmpty(DropdownSelected))
        {
            DropdownSelected = "انتخاب کنید";
        }
        await OnItemSelected.InvokeAsync(Item);
        await JS.InvokeVoidAsync("eval", "toggleDropdown()");

    }
    
    /// <summary>
    /// لود دیتای گرید
    /// </summary>
