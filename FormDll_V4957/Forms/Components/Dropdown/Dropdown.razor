    public async Task LoadData()
    {
        await RefDataGrid.LoadData();
    }

    public async Task Search(QueryBuilderFilterRule Filter)
    {
        await RefDataGrid.SearchFilter(Filter);
    }

    /// <summary>
    /// در صورت نیاز به آدرس از اینجا لود می شود
    /// </summary>
    /// <param name="SearchText"></param>
    /// <returns></returns>
     public async Task LoadData(string SearchText)
     { 
         var ListColumn = new List<View_values>(); 
         if (Component.data is not null && !string.IsNullOrEmpty(Component.data.url))
         { 
             string Url = Component.data.url; 
             if (!string.IsNullOrEmpty(SearchText))
             {//اگه تکست جستجو پره اونم ارسال کنه
                if (!Url.Contains("?"))
                { Url += "?"; }
                else
                { Url += "&"; }
                Url += $"{Component.valueProperty}=" + SearchText; 
             } 
             try
             {
                 var GetData = await Http.GetStringAsync(Url);
              
                 // Attempt to parse the response as a JToken
                 JToken data = JToken.Parse(GetData);
     
                 string item_ = "";
                 List<KeyValuePair<string, string>> list = await ConvertParameter.GetTemplate(Component.template);
              
                 // Check if the data is an array
                 if (data.Type == JTokenType.Array)
                 {
                     // Process the first item in the array
                     var firstItem = data.First;
                     for (int i = 0; i < list.Count; i++)
                     {
                         Console.WriteLine(list[i]);
                         item_ = list[i].Key;
                         if (i == 0)
                         {
                             DropdownSelected = firstItem[item_].ToString();
                         }
                         else
                         {
                             DropdownSelected += " " + firstItem[item_];
                         }
                     }
                 }
                 else if (data.Type == JTokenType.Object)
                 {
                     // Process as an object if needed
                     for (int i = 0; i < list.Count; i++)
                     {
                         Console.WriteLine(list[i]);
                         item_ = list[i].Key;
                         if (i == 0)
                         {
                             DropdownSelected = data[item_].ToString();
                         }
                         else
                         {
                             DropdownSelected += " " + data[item_];
                         }
                     }
                 } 
             }
             catch (Exception ex)
             {
                 Console.WriteLine(ex.Message);
             }
             
     
         }
     
     }

 /// <summary>
 /// در صورت نیاز به آدرس از اینجا لود می شود با فیلتر
 /// </summary>
 /// <param name="Filter"></param>
 /// <returns></returns>
 public async Task LoadData(QueryBuilderFilterRule Filter)
 {
     var ListColumn = new List<View_values>();
     if (Component.data is not null && !string.IsNullOrEmpty(Component.data.url))
     {
         string Url = Component.data.url;
         if (Filter != null)
         {//اگه فیلتر پره اونم ارسال کنه
             var filterJson = JsonConvert.SerializeObject(Filter);
             if (!Url.Contains("?"))
             { Url += "?"; }
             else
             { Url += "&"; }
             Url += $"Filter=" + Uri.EscapeDataString(filterJson);
         }
         try
         {
             var GetData = await Http.GetStringAsync(Url);

             // Attempt to parse the response as a JToken
             JToken data = JToken.Parse(GetData);

             string item_ = "";
             List<KeyValuePair<string, string>> list = await ConvertParameter.GetTemplate(Component.template);

             // Check if the data is an array
             if (data.Type == JTokenType.Array)
             {
                 // Process the first item in the array
                 var firstItem = data.First;
                 for (int i = 0; i < list.Count; i++)
                 {
                     Console.WriteLine(list[i]);
                     item_ = list[i].Key;
                     if (i == 0)
                     {
                         DropdownSelected = firstItem[item_].ToString();
                     }
                     else
                     {
                         DropdownSelected += " " + firstItem[item_];
                     }
                 }
             }
             else if (data.Type == JTokenType.Object)
             {
                 // Process as an object if needed
                 for (int i = 0; i < list.Count; i++)
                 {
                     Console.WriteLine(list[i]);
                     item_ = list[i].Key;
                     if (i == 0)
                     {
                         DropdownSelected = data[item_].ToString();
                     }
                     else
                     {
                         DropdownSelected += " " + data[item_];
                     }
                 }
             }
         }
         catch (Exception ex)
         {
             Console.WriteLine(ex.Message);
         }


     }

 }

