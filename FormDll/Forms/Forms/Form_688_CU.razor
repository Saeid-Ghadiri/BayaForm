<div class="col-md-8">
    
<div class="">
    <div  class="">
    <!-- HTML Structure -->
<div id="bankAccountGuide">
    <!-- Header Section -->
    <div class="guide-header">
        <h2>📋 راهنمای تکمیل فرم اطلاعات حساب بانکی</h2>
        <p>لطفاً مراحل زیر را به ترتیب دنبال کنید</p>
    </div>

    <!-- Step 1: نوع صاحب حساب -->
    <div class="guide-step step-account-type">
        <div class="step-title">
            <span class="step-number">1</span>
            <h3>انتخاب نوع صاحب حساب بانکی</h3>
        </div>
        
        <div class="step-content info-blue">
            <ul>
                <li><strong>کارمند:</strong> اگر حساب بانکی متعلق به خود کارمند است</li>
                <li><strong>همسر:</strong> اگر حساب بانکی متعلق به همسر کارمند است</li>
            </ul>
        </div>
        
        <div class="step-note warning">
            <strong>⚠️ نکته مهم:</strong>
            <p>پس از انتخاب نوع صاحب حساب، فیلدهای مربوطه به طور خودکار نمایش داده می‌شوند.</p>
        </div>
    </div>

    <!-- Step 2: انتخاب کارمند/همسر -->
    <div class="guide-step step-employee-spouse">
        <div class="step-title">
            <span class="step-number">2</span>
            <h3>انتخاب کارمند و همسر</h3>
        </div>
        
        <div class="step-content info-red">
            <ul>
                <li><strong>در حالت "کارمند":</strong> فقط فیلد انتخاب کارمند نمایش داده می‌شود</li>
                <li><strong>در حالت "همسر":</strong> دو فیلد نمایش داده می‌شود:
                    <ul class="nested-list">
                        <li>انتخاب کارمند</li>
                        <li>انتخاب همسر (پس از انتخاب کارمند، لیست همسران بارگذاری می‌شود)</li>
                    </ul>
                </li>
            </ul>
        </div>
        
        <div class="step-note success">
            <strong>✅ توجه:</strong>
            <p>اگر همسری برای کارمند پیدا نشد، ابتدا از پنل ادمین، اطلاعات همسر را ثبت کنید.</p>
        </div>
    </div>

    <!-- Step 3: اطلاعات بانکی -->
    <div class="guide-step step-bank-info">
        <div class="step-title">
            <span class="step-number">3</span>
            <h3>وارد کردن اطلاعات بانکی</h3>
        </div>
        
        <div class="step-content info-green">
            <table class="format-table">
                <tr>
                    <th>فیلد</th>
                    <th>فرمت صحیح</th>
                    <th>مثال</th>
                </tr>
                <tr>
                    <td>شماره شبا (IBAN)</td>
                    <td>26 کاراکتر با پیشوند IR</td>
                    <td class="code">IR620100000000000000000001</td>
                </tr>
                <tr>
                    <td>شماره کارت</td>
                    <td>16 رقم</td>
                    <td class="code">6037991234567890</td>
                </tr>
                <tr>
                    <td>شماره حساب</td>
                    <td>بدون محدودیت خاص</td>
                    <td class="code">010000000000000000000001</td>
                </tr>
            </table>
        </div>
        
        <div class="step-note warning">
            <strong>⚠️ هشدارهای مهم:</strong>
            <ul>
                <li>شماره شبا <strong>حتماً</strong> باید با <code>IR</code> شروع شود</li>
                <li>تعداد کاراکترهای شبا باید دقیقاً <strong>26</strong> کاراکتر باشد</li>
                <li>شماره کارت باید دقیقاً <strong>16</strong> رقم باشد</li>
                <li>کد شعبه و نام شعبه اختیاری هستند</li>
            </ul>
        </div>
    </div>

    <!-- Step 4: دسته‌بندی و بانک -->
    <div class="guide-step step-category-bank">
        <div class="step-title">
            <span class="step-number">4</span>
            <h3>انتخاب دسته‌بندی و بانک</h3>
        </div>
        
        <div class="step-content info-purple">
            <ul>
                <li><strong>دسته‌بندی حساب:</strong> نوع حساب بانکی را انتخاب کنید (مثلاً حقوق و دستمزد)</li>
                <li><strong>بانک:</strong> نام بانک را انتخاب کنید</li>
                <li><strong>نکته ویژه:</strong> اگر دسته‌بندی "حقوق و دستمزد" را انتخاب کنید، بانک به طور خودکار به "سپه" تنظیم می‌شود</li>
            </ul>
        </div>
    </div>

    <!-- Final Notes Section -->
    <div class="guide-final-notes">
        <h3><span>📌</span> نکات نهایی قبل از ثبت</h3>
        
        <ul>
            <li>همه فیلدهای ستاره‌دار (<span class="required">*</span>) اجباری هستند</li>
            <li>اطلاعات وارد شده را دوباره بررسی کنید</li>
            <li>نام صاحب حساب باید با نام فرد انتخاب شده یکسان باشد</li>
            <li>پس از ثبت، امکان ویرایش محدود است</li>
        </ul>
        
        <div class="responsibility-note">
            <strong>⚠️ مسئولیت:</strong>
            <span>صحت اطلاعات وارد شده کاملاً بر عهده کارمند/مدیر مربوطه است.</span>
        </div>
    </div>

    <!-- Quick Reference Card -->
    <div class="guide-quick-reference">
        <div class="quick-ref-header">
            <span class="quick-ref-icon">!</span>
            <strong>خلاصه سریع</strong>
        </div>
        
        <div class="quick-ref-grid">
            <div class="quick-ref-item">
                <div class="ref-title">شبا</div>
                <div class="ref-desc">26 کاراکتر با IR</div>
            </div>
            <div class="quick-ref-item">
                <div class="ref-title">کارت</div>
                <div class="ref-desc">16 رقم</div>
            </div>
            <div class="quick-ref-item">
                <div class="ref-title">صاحب حساب</div>
                <div class="ref-desc">کارمند یا همسر</div>
            </div>
            <div class="quick-ref-item">
                <div class="ref-title">بانک</div>
                <div class="ref-desc">اختیاری</div>
            </div>
        </div>
    </div>
</div>
</div>

</div>

