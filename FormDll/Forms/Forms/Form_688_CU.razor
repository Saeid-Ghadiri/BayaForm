<style>
    /* ************************************************** */
.detailArea form div:not(.devdrop) {
    margin-top: .1rem;
}

.force-left input {
    text-align: left !important;
}

/* ************************************************** */

.form-header {
    background: linear-gradient(to bottom, #6c5ffc, #0d1a52);
    color: white;
    padding: 1.5rem 2rem;
    border-radius: 0.5rem 0.5rem 0 0;
    margin-bottom: 0;
    position: relative;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
    transition: all 0.3s ease;
}

.form-header:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 25px rgba(0, 0, 0, 0.2);
}

.form-header h2 {
    font-weight: 700;
    margin-bottom: 0;
    display: flex;
    align-items: center;
    position: relative;
    z-index: 2;
}

.form-header .icon {
    font-size: 1.8rem;
    margin-left: 15px;
    animation: float 3s ease-in-out infinite;
}

.form-header::before {
    content: "";
    position: absolute;
    top: -50%;
    right: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, rgba(255, 255, 255, 0) 70%);
    transform: rotate(45deg);
    z-index: 1;
    transition: all 0.5s ease;
}

.form-header:hover::before {
    transform: rotate(45deg) translate(20px, 20px);
}

.form-header .decoration {
    position: absolute;
    width: 100px;
    height: 100px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.05);
    z-index: 1;
}

.form-header .decoration-1 {
    top: -30px;
    left: -30px;
    width: 120px;
    height: 120px;
}

.form-header .decoration-2 {
    bottom: -40px;
    right: -20px;
    width: 80px;
    height: 80px;
}

@@keyframes float {
    0% {
        transform: translateY(0px);
    }

    50% {
        transform: translateY(-5px);
    }

    100% {
        transform: translateY(0px);
    }
}

@@keyframes pulse {
    0% {
        opacity: 0.3;
    }

    50% {
        opacity: 0.1;
    }

    100% {
        opacity: 0.3;
    }
}

.pulse-animation {
    animation: pulse 4s ease-in-out infinite;
}

/* ************************************************** */
.lrt-input input {
    direction: ltr !important;
}

/* ************************************************** */
/* ========================================
   Main Container
   ======================================== */
#bankAccountGuide {
    background: linear-gradient(135deg, #f8f9fa, #e9ecef);
    border-radius: 16px;
    padding: 25px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    box-shadow: 0 6px 16px rgba(0,0,0,0.05);
    border: 1px solid #dee2e6;
    height: 550px;
    max-height: 550px;
    overflow-y: auto;
    overflow-x: hidden;
}

/* ========================================
   Scrollbar Styling
   ======================================== */
#bankAccountGuide::-webkit-scrollbar {
    width: 8px;
}
#bankAccountGuide::-webkit-scrollbar-track {
    background: #f1f1f1;
    border-radius: 10px;
}
#bankAccountGuide::-webkit-scrollbar-thumb {
    background: #1b3b5f;
    border-radius: 10px;
    transition: background 0.3s;
}
#bankAccountGuide::-webkit-scrollbar-thumb:hover {
    background: #39609b;
}

/* ========================================
   Header Section
   ======================================== */
.guide-header {
    text-align: center;
    padding-bottom: 15px;
    border-bottom: 2px solid #4a90e2;
}
.guide-header h2 {
    margin: 0;
    font-size: 22px;
    font-weight: 700;
    color: #2c3e50;
    letter-spacing: -0.5px;
}
.guide-header p {
    margin: 8px 0 0;
    font-size: 13px;
    color: #6c757d;
    font-weight: 500;
}

/* ========================================
   Guide Steps
   ======================================== */
.guide-step {
    background: white;
    border-radius: 12px;
    padding: 18px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
}
.step-title {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 12px;
}
.step-number {
    background: #4a90e2;
    color: white;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    font-size: 14px;
}
.step-title h3 {
    margin: 0;
    font-size: 16px;
    font-weight: 700;
    color: #2c3e50;
}
.step-account-type { border-left: 4px solid #4a90e2; }
.step-employee-spouse { border-left: 4px solid #e27d60; }
.step-bank-info { border-left: 4px solid #85ad88; }
.step-category-bank { border-left: 4px solid #6a4c93; }

/* ========================================
   Step Content
   ======================================== */
.step-content {
    padding: 12px;
    border-radius: 8px;
    margin-top: 10px;
}
.step-content ul {
    margin: 0;
    padding-right: 20px;
    line-height: 1.7;
}
.step-content li {
    margin-bottom: 4px;
}
.nested-list {
    margin: 8px 0 0 !important;
    padding-right: 25px !important;
}
.info-blue { background: #e3f2fd; color: #1565c0; }
.info-red { background: #ffebee; color: #c62828; }
.info-green { background: #f1f8e9; color: #2e7d32; }
.info-purple { background: #f3e5f5; color: #4a148c; }

/* ========================================
   Step Notes
   ======================================== */
.step-note {
    margin-top: 12px;
    padding: 10px 12px;
    border-radius: 8px;
    border-right: 3px solid;
}
.step-note strong {
    display: block;
    margin-bottom: 4px;
}
.step-note p {
    margin: 0;
    font-size: 12px;
    line-height: 1.6;
}
.warning {
    background: #fff8e1;
    border-right-color: #ffc107;
    color: #e65100;
}
.success {
    background: #e8f5e9;
    border-right-color: #4caf50;
    color: #1b5e20;
}

/* ========================================
   Format Table
   ======================================== */
.format-table {
    width: 100%;
    font-size: 13px;
    border-collapse: collapse;
}
.format-table th {
    padding: 10px;
    background: #c8e6c9;
    text-align: right;
    font-weight: bold;
    color: #1b5e20;
}
.format-table td {
    padding: 8px;
    border-bottom: 1px solid #c8e6c9;
}
.format-table tr:last-child td {
    border-bottom: none;
}
.format-table .code {
    direction: ltr;
    font-family: 'Courier New', monospace;
    font-size: 12px;
}

/* ========================================
   Final Notes Section
   ======================================== */
.guide-final-notes {
    background: linear-gradient(135deg, #2c3e50, #1a252f);
    border-radius: 12px;
    padding: 20px;
    color: white;
    margin-top: 10px;
}
.guide-final-notes h3 {
    margin: 0 0 12px;
    font-size: 16px;
    font-weight: 700;
    display: flex;
    align-items: center;
    gap: 8px;
}
.guide-final-notes ul {
    margin: 0;
    padding-right: 25px;
    font-size: 13px;
    line-height: 1.8;
}
.guide-final-notes li {
    margin-bottom: 6px;
}
.required {
    color: #ff6b6b;
}
.responsibility-note {
    margin-top: 15px;
    padding: 12px;
    background: rgba(255,255,255,0.1);
    border-radius: 8px;
    border-left: 3px solid #ff6b6b;
}
.responsibility-note strong {
    display: block;
    margin-bottom: 6px;
}
.responsibility-note span {
    font-size: 12px;
    opacity: 0.9;
}

/* ========================================
   Quick Reference Card
   ======================================== */
.guide-quick-reference {
    background: white;
    border-radius: 12px;
    padding: 15px;
    border: 2px solid #4a90e2;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    margin-bottom: 10px;
}
.quick-ref-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 10px;
}
.quick-ref-icon {
    background: #4a90e2;
    color: white;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    font-size: 12px;
}
.quick-ref-header strong {
    color: #2c3e50;
    font-size: 14px;
}
.quick-ref-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 10px;
    font-size: 12px;
}
.quick-ref-item {
    padding: 8px;
    border-radius: 6px;
    text-align: center;
}
.quick-ref-item:nth-child(1) { background: #e3f2fd; }
.quick-ref-item:nth-child(2) { background: #e8f5e9; }
.quick-ref-item:nth-child(3) { background: #fff3e0; }
.quick-ref-item:nth-child(4) { background: #f3e5f5; }
.ref-title {
    font-weight: bold;
    margin-bottom: 4px;
}
.quick-ref-item:nth-child(1) .ref-title { color: #1565c0; }
.quick-ref-item:nth-child(2) .ref-title { color: #2e7d32; }
.quick-ref-item:nth-child(3) .ref-title { color: #e65100; }
.quick-ref-item:nth-child(4) .ref-title { color: #4a148c; }
.ref-desc {
    color: #546e7a;
    font-size: 11px;
}

/* ========================================
   Code Tag
   ======================================== */
code {
    background: #fff3e0;
    padding: 2px 6px;
    border-radius: 3px;
    font-family: 'Courier New', monospace;
    font-size: 12px;
}
</style>

