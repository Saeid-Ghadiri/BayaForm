<style>
    /* ************************************************** */
.detailArea form div:not(.devdrop) {
    margin-top: .1rem;
}

/* ************************************************** */

purple_bg {
    background: #93b0ff0d;
    border: 1px dashed #6c5ffc45;
}

/* ************************************************** */
.form-header {
    background: linear-gradient(to bottom, #6c5ffc, #0d1a52);
    color: white;
    padding: 1.5rem 2rem;
    border-radius: 0.5rem 0.5rem 0 0;
    margin-bottom: 0;
    position: relative;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
    transition: all 0.3s ease;
}

.form-header:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 25px rgba(0, 0, 0, 0.2);
}

.form-header h2 {
    font-weight: 700;
    margin-bottom: 0;
    display: flex;
    align-items: center;
    position: relative;
    z-index: 2;
}

.form-header .icon {
    font-size: 1.8rem;
    margin-left: 15px;
    animation: float 3s ease-in-out infinite;
}

.form-header::before {
    content: "";
    position: absolute;
    top: -50%;
    right: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, rgba(255, 255, 255, 0) 70%);
    transform: rotate(45deg);
    z-index: 1;
    transition: all 0.5s ease;
}

.form-header:hover::before {
    transform: rotate(45deg) translate(20px, 20px);
}

.form-header .decoration {
    position: absolute;
    width: 100px;
    height: 100px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.05);
    z-index: 1;
}

.form-header .decoration-1 {
    top: -30px;
    left: -30px;
    width: 120px;
    height: 120px;
}

.form-header .decoration-2 {
    bottom: -40px;
    right: -20px;
    width: 80px;
    height: 80px;
}

@@keyframes float {
    0% {
        transform: translateY(0px);
    }

    50% {
        transform: translateY(-5px);
    }

    100% {
        transform: translateY(0px);
    }
}

@@keyframes pulse {
    0% {
        opacity: 0.3;
    }

    50% {
        opacity: 0.1;
    }

    100% {
        opacity: 0.3;
    }
}

.pulse-animation {
    animation: pulse 4s ease-in-out infinite;
}

/* ************************************************** */

/* Id: TypeBonusPaymentRadioButton */
.radioinlineblock #TypeBonusPaymentRadioButton {
    display: inline-block;
}

/* ************************************************** */
.input-ymd input {
    display: inline-block;
    max-width: 120px !important;
    background: none !important;
    border: none;
    color: #6c5ffc;
    font-size: 18px;
    text-align: center;
    font-weight: 650;
}

/* ************************************************** */
.input-string input {
    display: inline-block;
    max-width: 140px !important;
    background: none !important;
    border: none;
    color: #3928f3;
    text-align: end;
    font-size: 18px;
    font-weight: 700;
}

/* ************************************************** */
.Col_bg1 {
    border: 1px dashed rgb(255, 208, 139);
    background: rgba(255, 193, 7, 0.04);
    margin-left: 2px;
    margin-right: 2px;
    padding-bottom: 16px;
    border-radius: var(--bs-border-radius) !important;
    margin-top: 1rem !important;
    align-items: baseline;
}


.col_grid {
    border: 1px dashed rgba(255, 193, 7, 0.3);
    background-color: transparent;
    border-radius: 0.5rem;
    padding: 0.5rem;
    margin: 1rem 0.1rem !important;
    /*align-items: baseline;*/
}

.col_grid:hover {
    background-color: rgba(255, 193, 7, 0.03);
    border-color: rgba(255, 193, 7, 0.5);
}

/* ************************************************** */

/* هدر بخش گرید فرم */
.form-section-header {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: linear-gradient(90deg, rgba(255, 255, 255, 0.15), rgba(17, 0, 201, 0.371));
    color: #000437;
    padding: 0.4rem 0.8rem;
    border-radius: 0.5rem;
    font-weight: 600;
    font-size: 0.95rem;
    margin-bottom: 0.75rem;
}

/*  آیکون هدر گرید فرم */
.form-section-header i {
    font-size: 1.1rem;
    color: #50738e8a;
}

/* ************************************************** */

.dxbl-grid-table .html-visible {
    display: none !important;
}

/* ************************************************** */
</style>

