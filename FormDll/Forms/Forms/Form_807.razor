    border: 1px dashed #e2ae00e2;
}

/* ************************************************** */
/* Guide Step Animation */
.guide-step {
    transition: all 0.3s ease;
}

.guide-step:hover {
    transform: translateY(-2px);
}

/* Highlight Text Effect */
.highlight-text {
    position: relative;
    z-index: 1;
}

.highlight-text::before {
    content: '';
    position: absolute;
    bottom: 2px;
    right: 0;
    width: 100%;
    height: 40%;
    background-color: rgba(13, 110, 253, 0.15);
    z-index: -1;
    border-radius: 3px;
    transition: all 0.3s ease;
}

.highlight-text:hover::before {
    height: 60%;
    background-color: rgba(13, 110, 253, 0.25);
}

/* Custom Card Styles */
.rounded-4 {
    border-radius: 1rem !important;
}

/* Responsive Adjustments */
@@media (max-width: 768px) {
    .card-header {
        padding: 1rem;
    }

    .card-body {
        padding: 1.5rem;
    }

    .guide-step {
        padding: 1.25rem;
    }
}

/* ************************************************** */
</style>

