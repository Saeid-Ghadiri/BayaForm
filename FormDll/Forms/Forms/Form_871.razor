@code {
    // DxGrid? Grid_Shomaran_InsertParts;
    Entity.Shomaran_InsertParts Shomaran_InsertParts;
    bool ConfirmationShownShomaran_InsertParts { get; set; } = false;
    public Entity.Shomaran_InsertParts SelectedItemGrid_Shomaran_InsertParts { get; set; } = new Entity.Shomaran_InsertParts();
    /// <summary>
    /// شماره ستون
    /// </summary>
