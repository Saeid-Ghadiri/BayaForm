    /// <returns></returns>
    public async Task setFocusOff()
    {
        //اگر فوکوس روشن بود خاموشش کن
        if (Grid_Shomaran_InsertParts.FocusedRowEnabled)
    {
            //به علت یروزرسانی دیتاگرید و اینکه فوکوس باید مقدار اولیه داده شود از خط زیر استفاده می شود
            Grid_Shomaran_InsertParts.BeginUpdate();
    Grid_Shomaran_InsertParts.FocusedRowEnabled = false;
    Grid_Shomaran_InsertParts.EndUpdate();
    }

    }
    /// <summary>
    /// فعال کردن فوکوس گرید
    /// </summary>
    /// <returns></returns>
    public async Task setFocusOn()
    {
        if (!Grid_Shomaran_InsertParts.FocusedRowEnabled)
    {
            Grid_Shomaran_InsertParts.BeginUpdate();
    Grid_Shomaran_InsertParts.FocusedRowEnabled = true;

    Grid_Shomaran_InsertParts.EndUpdate();
    }

    }

    public async Task SelectRecord(int PageIndex, int __VisibleIndex)
    {

        isSending = true;
        await setFocusOn();
        PageIndexChanged(PageIndex);
        await ShowFormCU(Grid_Shomaran_InsertParts.GetDataItem(__VisibleIndex));
    DxPager.ActivePageIndex = PageIndex;
        Grid_Shomaran_InsertParts.BeginUpdate();
    Grid_Shomaran_InsertParts.PageIndex = PageIndex;
    Grid_Shomaran_InsertParts.EndUpdate();
    Grid_Shomaran_InsertParts.SetFocusedRowIndex(__VisibleIndex);

    isSending = false;
    }

    public async Task SetPageIndex(int Index)
    {
