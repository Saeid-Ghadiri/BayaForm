    ///////////////////////
    bool ConfirmationShomaran_InsertParts { get; set; } = false;
    GridEditFormTemplateContext? _ContextFormTemplateShomaran_InsertParts { get; set; }
    public int OpenDialogCodeShomaran_InsertParts { get; set; } = 0;
    ////////////////////////

    async Task OnEditModelSavingShomaran_InsertParts(GridEditModelSavingEventArgs arg)
    {
        var e = arg.EditModel;
    bool NotValid = false;
    //events
       
        
      if (!NotValid)
     {
      SaveGrid_Shomaran_InsertParts(arg.DataItem, arg.EditModel);
     }
}

async void Dialog_Grid_Shomaran_InsertParts(int _OpenDialogCode, int VisibleIndex, GridEditFormTemplateContext e)
{
    OpenDialogCodeShomaran_InsertParts = _OpenDialogCode;
    if (!CheckChangedData(await Utility.JSON.ToJson(e.EditModel)))
    {
    _ContextFormTemplateShomaran_InsertParts = e;
    ConfirmationShomaran_InsertParts = true;
    }
    else
    {
    await OnNoButtonShomaran_InsertParts();
    }
}
async Task OnYesButtonShomaran_InsertParts()
{

    ConfirmationShomaran_InsertParts = false;
    await Task.Delay(1500);
    //bool FormValidate = await JSO.InvokeAsync<bool>("submitForm");
    bool FormValidate =  await JS.InvokeAsync<bool>("submitForm");
    if (FormValidate)
    {
        bool NotValid = false;
    var e = _ContextFormTemplateShomaran_InsertParts.EditModel;
         //events
         

        if (!NotValid)
         {
        SaveGrid_Shomaran_InsertParts(_ContextFormTemplateShomaran_InsertParts.DataItem, _ContextFormTemplateShomaran_InsertParts.EditModel);
            await Grid_Shomaran_InsertParts.CancelEditAsync();
         await ChangePageGrid_Shomaran_InsertParts();
         await SetEditFormContextGrid_Shomaran_InsertParts();
         }
          
    }

}
async Task OnNoButtonShomaran_InsertParts()
{
    ConfirmationShomaran_InsertParts = false;
    await ChangePageGrid_Shomaran_InsertParts();
    await SetEditFormContextGrid_Shomaran_InsertParts();

}
async Task SetEditFormContextGrid_Shomaran_InsertParts()
{
    var e = (Entity.Shomaran_InsertParts)Grid_Shomaran_InsertParts.GetDataItem(IndexGrid_Shomaran_InsertParts);
    JsonData = await Utility.JSON.ToJson(e);
}

async Task ChangePageGrid_Shomaran_InsertParts()
{
    int VisibleIndex = IndexGrid_Shomaran_InsertParts;
    try
    {
    if (OpenDialogCodeShomaran_InsertParts == 1)
    {
        if (VisibleIndex != (Grid_Shomaran_InsertParts.GetVisibleRowCount() - 1))
    { 
            Grid_Shomaran_InsertParts.CancelEditAsync();
            IndexGrid_Shomaran_InsertParts = VisibleIndex + 1;
    Grid_Shomaran_InsertParts.StartEditRowAsync(IndexGrid_Shomaran_InsertParts);
    }
    }
    else if (OpenDialogCodeShomaran_InsertParts == 0)
    {
        if (VisibleIndex != 0)
        {

            Grid_Shomaran_InsertParts.CancelEditAsync();
            IndexGrid_Shomaran_InsertParts = VisibleIndex - 1;
