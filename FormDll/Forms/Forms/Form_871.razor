.header-form {
  height: 100px;
  background: linear-gradient(96deg, #0d3b66, #6a0dad);
  color: white;
  border-bottom: 2px solid #ffffff33;
  box-shadow: 0 6px 12px rgba(0, 0, 0, 0.25);
  border-radius: 10px;
  transition: all 0.3s ease-in-out;
}

.header-icon {
  font-size: 56px;
  color: #ffccff;
  transition: transform 0.3s ease, color 0.3s ease;
}

.header-icon:hover {
  transform: scale(1.1) rotate(-5deg);
  color: #f5baff;
}

.header-title {
  font-size: 25px;
  font-weight: bold;
  transition: color 0.3s ease;
}

.header-subtitle {
  font-size: 14px;
  opacity: 0.95;
  transition: opacity 0.3s ease;
}

.header-text:hover .header-title {
  color: #ffe0ff;
}

.header-text:hover .header-subtitle {
  opacity: 1;
}
</style>

