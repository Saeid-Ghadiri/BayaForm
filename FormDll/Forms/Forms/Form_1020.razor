async void Dialog_Grid_SH_Petco_InsertParts(int _OpenDialogCode, int VisibleIndex, GridEditFormTemplateContext e)
{
    OpenDialogCodeSH_Petco_InsertParts = _OpenDialogCode;
    if (!CheckChangedData(await Utility.JSON.ToJson(e.EditModel)))
    {
    _ContextFormTemplateSH_Petco_InsertParts = e;
    ConfirmationSH_Petco_InsertParts = true;
    }
    else
    {
    await OnNoButtonSH_Petco_InsertParts();
    }
}
async Task OnYesButtonSH_Petco_InsertParts()
{

    ConfirmationSH_Petco_InsertParts = false;
    await Task.Delay(1500);
    //bool FormValidate = await JSO.InvokeAsync<bool>("submitForm");
    bool FormValidate =  await JS.InvokeAsync<bool>("submitForm");
    if (FormValidate)
    {
        bool NotValid = false;
    var e = _ContextFormTemplateSH_Petco_InsertParts.EditModel;
         //events
         

        if (!NotValid)
         {
        SaveGrid_SH_Petco_InsertParts(_ContextFormTemplateSH_Petco_InsertParts.DataItem, _ContextFormTemplateSH_Petco_InsertParts.EditModel);
            await Grid_SH_Petco_InsertParts.CancelEditAsync();
         await ChangePageGrid_SH_Petco_InsertParts();
         await SetEditFormContextGrid_SH_Petco_InsertParts();
         }
          
    }

}
async Task OnNoButtonSH_Petco_InsertParts()
{
    ConfirmationSH_Petco_InsertParts = false;
    await ChangePageGrid_SH_Petco_InsertParts();
    await SetEditFormContextGrid_SH_Petco_InsertParts();

}
async Task SetEditFormContextGrid_SH_Petco_InsertParts()
{
    var e = (Entity.SH_Petco_InsertParts)Grid_SH_Petco_InsertParts.GetDataItem(IndexGrid_SH_Petco_InsertParts);
    JsonData = await Utility.JSON.ToJson(e);
}

async Task ChangePageGrid_SH_Petco_InsertParts()
{
    int VisibleIndex = IndexGrid_SH_Petco_InsertParts;
    try
    {
    if (OpenDialogCodeSH_Petco_InsertParts == 1)
    {
        if (VisibleIndex != (Grid_SH_Petco_InsertParts.GetVisibleRowCount() - 1))
    { 
            Grid_SH_Petco_InsertParts.CancelEditAsync();
            IndexGrid_SH_Petco_InsertParts = VisibleIndex + 1;
    Grid_SH_Petco_InsertParts.StartEditRowAsync(IndexGrid_SH_Petco_InsertParts);
    }
    }
    else if (OpenDialogCodeSH_Petco_InsertParts == 0)
    {
        if (VisibleIndex != 0)
        {

            Grid_SH_Petco_InsertParts.CancelEditAsync();
            IndexGrid_SH_Petco_InsertParts = VisibleIndex - 1;
    Grid_SH_Petco_InsertParts.StartEditRowAsync(IndexGrid_SH_Petco_InsertParts);
    }

    }
    var e = (Entity.SH_Petco_InsertParts)Grid_SH_Petco_InsertParts.GetDataItem(IndexGrid_SH_Petco_InsertParts);
    JsonData = await Utility.JSON.ToJson(e);
    await Task.Delay(300);
    
    StateHasChanged();
    }
    catch (Exception ex)
    {

    Console.WriteLine("error in ChagePage" + ex.Message);
    }

}

