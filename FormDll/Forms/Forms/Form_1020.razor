    {
        if (!Grid_SH_Petco_InsertParts.FocusedRowEnabled)
    {
            Grid_SH_Petco_InsertParts.BeginUpdate();
    Grid_SH_Petco_InsertParts.FocusedRowEnabled = true;

    Grid_SH_Petco_InsertParts.EndUpdate();
    }

    }

    public async Task SelectRecord(int PageIndex, int __VisibleIndex)
    {

        isSending = true;
        await setFocusOn();
        PageIndexChanged(PageIndex);
        await ShowFormCU(Grid_SH_Petco_InsertParts.GetDataItem(__VisibleIndex));
    DxPager.ActivePageIndex = PageIndex;
        Grid_SH_Petco_InsertParts.BeginUpdate();
    Grid_SH_Petco_InsertParts.PageIndex = PageIndex;
    Grid_SH_Petco_InsertParts.EndUpdate();
    Grid_SH_Petco_InsertParts.SetFocusedRowIndex(__VisibleIndex);

    isSending = false;
    }

