async Task ChangePageGrid_BaseInfo_Banks()
{
    int VisibleIndex = IndexGrid_BaseInfo_Banks;
    try
    {
    if (OpenDialogCodeBaseInfo_Banks == 1)
    {
        if (VisibleIndex != (Grid_BaseInfo_Banks.GetVisibleRowCount() - 1))
    { 
            Grid_BaseInfo_Banks.CancelEditAsync();
            IndexGrid_BaseInfo_Banks = VisibleIndex + 1;
    Grid_BaseInfo_Banks.StartEditRowAsync(IndexGrid_BaseInfo_Banks);
    }
    }
    else if (OpenDialogCodeBaseInfo_Banks == 0)
    {
        if (VisibleIndex != 0)
        {

            Grid_BaseInfo_Banks.CancelEditAsync();
            IndexGrid_BaseInfo_Banks = VisibleIndex - 1;
    Grid_BaseInfo_Banks.StartEditRowAsync(IndexGrid_BaseInfo_Banks);
    }

    }
    var e = (Entity.BaseInfo_Banks)Grid_BaseInfo_Banks.GetDataItem(IndexGrid_BaseInfo_Banks);
    JsonData = await Utility.JSON.ToJson(e);
    await Task.Delay(300);
    
    StateHasChanged();
    }
    catch (Exception ex)
    {

    Console.WriteLine("error in ChagePage" + ex.Message);
    }

}

