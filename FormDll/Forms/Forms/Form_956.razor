    public async Task SelectRecord(int PageIndex, int __VisibleIndex)
    {

        isSending = true;
        await setFocusOn();
        PageIndexChanged(PageIndex);
        await ShowFormCU(Grid_SH_PolFilm_InsertParts.GetDataItem(__VisibleIndex));
    DxPager.ActivePageIndex = PageIndex;
        Grid_SH_PolFilm_InsertParts.BeginUpdate();
    Grid_SH_PolFilm_InsertParts.PageIndex = PageIndex;
    Grid_SH_PolFilm_InsertParts.EndUpdate();
    Grid_SH_PolFilm_InsertParts.SetFocusedRowIndex(__VisibleIndex);

    isSending = false;
    }

