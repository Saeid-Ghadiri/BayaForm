async Task OnYesButtonIDMS_RDC_Details()
{

    ConfirmationIDMS_RDC_Details = false;
    await Task.Delay(1500);
    //bool FormValidate = await JSO.InvokeAsync<bool>("submitForm");
    bool FormValidate =  await JS.InvokeAsync<bool>("submitForm");
    if (FormValidate)
    {
        bool NotValid = false;
    var e = _ContextFormTemplateIDMS_RDC_Details.EditModel;
