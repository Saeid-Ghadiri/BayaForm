}

async Task ChangePageGrid_IDMS_RDC_Details()
{
    int VisibleIndex = IndexGrid_IDMS_RDC_Details;
    try
    {
    if (OpenDialogCodeIDMS_RDC_Details == 1)
    {
        if (VisibleIndex != (Grid_IDMS_RDC_Details.GetVisibleRowCount() - 1))
    { 
            Grid_IDMS_RDC_Details.CancelEditAsync();
            IndexGrid_IDMS_RDC_Details = VisibleIndex + 1;
    Grid_IDMS_RDC_Details.StartEditRowAsync(IndexGrid_IDMS_RDC_Details);
    }
    }
    else if (OpenDialogCodeIDMS_RDC_Details == 0)
    {
        if (VisibleIndex != 0)
        {

            Grid_IDMS_RDC_Details.CancelEditAsync();
            IndexGrid_IDMS_RDC_Details = VisibleIndex - 1;
    Grid_IDMS_RDC_Details.StartEditRowAsync(IndexGrid_IDMS_RDC_Details);
    }

    }
    var e = (Entity.IDMS_RDC_Details)Grid_IDMS_RDC_Details.GetDataItem(IndexGrid_IDMS_RDC_Details);
    JsonData = await Utility.JSON.ToJson(e);
    await Task.Delay(300);
    await GridIDMS_RDC_MasterId_741_afterrendermodal(e);
    StateHasChanged();
    }
    catch (Exception ex)
    {

    Console.WriteLine("error in ChagePage" + ex.Message);
    }

}

