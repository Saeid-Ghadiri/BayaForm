    public async Task setFocusOn()
    {
        if (!Grid_HR_CVR_RecruitmentRules.FocusedRowEnabled)
    {
            Grid_HR_CVR_RecruitmentRules.BeginUpdate();
    Grid_HR_CVR_RecruitmentRules.FocusedRowEnabled = true;

    Grid_HR_CVR_RecruitmentRules.EndUpdate();
    }

    }

    public async Task SelectRecord(int PageIndex, int __VisibleIndex)
    {

        isSending = true;
        await setFocusOn();
        PageIndexChanged(PageIndex);
        await ShowFormCU(Grid_HR_CVR_RecruitmentRules.GetDataItem(__VisibleIndex));
    DxPager.ActivePageIndex = PageIndex;
        Grid_HR_CVR_RecruitmentRules.BeginUpdate();
    Grid_HR_CVR_RecruitmentRules.PageIndex = PageIndex;
    Grid_HR_CVR_RecruitmentRules.EndUpdate();
    Grid_HR_CVR_RecruitmentRules.SetFocusedRowIndex(__VisibleIndex);

    isSending = false;
    }

    public async Task SetPageIndex(int Index)
