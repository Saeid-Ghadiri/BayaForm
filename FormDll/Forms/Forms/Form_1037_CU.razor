async Task ChangePageGrid_HR_EMP_Documents()
{
    int VisibleIndex = IndexGrid_HR_EMP_Documents;
    try
    {
    if (OpenDialogCodeHR_EMP_Documents == 1)
    {
        if (VisibleIndex != (Grid_HR_EMP_Documents.GetVisibleRowCount() - 1))
    { 
