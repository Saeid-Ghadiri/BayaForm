async void Dialog_Grid_HR_EMP_Documents(int _OpenDialogCode, int VisibleIndex, GridEditFormTemplateContext e)
{
    OpenDialogCodeHR_EMP_Documents = _OpenDialogCode;
    if (!CheckChangedData(await Utility.JSON.ToJson(e.EditModel)))
    {
    _ContextFormTemplateHR_EMP_Documents = e;
    ConfirmationHR_EMP_Documents = true;
    }
    else
    {
    await OnNoButtonHR_EMP_Documents();
    }
}
async Task OnYesButtonHR_EMP_Documents()
{

    ConfirmationHR_EMP_Documents = false;
    await Task.Delay(1500);
    //bool FormValidate = await JSO.InvokeAsync<bool>("submitForm");
    bool FormValidate =  await JS.InvokeAsync<bool>("submitForm");
    if (FormValidate)
    {
        bool NotValid = false;
    var e = _ContextFormTemplateHR_EMP_Documents.EditModel;
         //events
         NotValid = await GridHR_EMP_EmployeesId_379_editmodelsaving(e);

        if (!NotValid)
         {
        SaveGrid_HR_EMP_Documents(_ContextFormTemplateHR_EMP_Documents.DataItem, _ContextFormTemplateHR_EMP_Documents.EditModel);
            await Grid_HR_EMP_Documents.CancelEditAsync();
         await ChangePageGrid_HR_EMP_Documents();
         await SetEditFormContextGrid_HR_EMP_Documents();
         }
          
    }

}
async Task OnNoButtonHR_EMP_Documents()
{
    ConfirmationHR_EMP_Documents = false;
    await ChangePageGrid_HR_EMP_Documents();
    await SetEditFormContextGrid_HR_EMP_Documents();

