async void OnYesButtonClickGrid_FileUploads_FileUploads ()
{
       if (SelectedItemGrid_FileUploads_FileUploads != null)
    {
      if (SelectedItemGrid_FileUploads_FileUploads.Id == Guid.Empty)
      {
          var ListEntity = _Entity.FileUploads_FileUploads;
        ListEntity.Remove((Entity.FileUploads_FileUploads)SelectedItemGrid_FileUploads_FileUploads);
     
      }
      else
      {
        var cleanModel = new Entity.FileUploads_FileUploads();
      // چک کن آیا پراپرتی IsDelete در این نوع وجود دارد؟
        var prop = typeof(Entity.FileUploads_FileUploads).GetProperty("IsDelete");
        if (prop != null && prop.CanRead && prop.CanWrite)
        {
            // مقدار فعلی را بگیر
            var currentValue = prop.GetValue(SelectedItemGrid_FileUploads_FileUploads);

            if (currentValue is bool boolValue)
            {
                // مقدار را معکوس کن
                var newValue = !boolValue;

                // روی هر دو شیء تنظیم کن
                prop.SetValue(SelectedItemGrid_FileUploads_FileUploads, newValue);
                prop.SetValue(cleanModel, newValue);
            }
        }
        EntityHelper.SetPropertyValue(cleanModel, cleanModel._GetIdName, SelectedItemGrid_FileUploads_FileUploads._Id);
    
       
       
      }
    }
    var e= SelectedItemGrid_FileUploads_FileUploads;
    
    Grid_FileUploads_FileUploads.Reload();
    ConfirmationShownFileUploads_FileUploads = false;
     await Task.Yield();
    await InvokeAsync(StateHasChanged);

}
