            IndexGrid_FileUploads_FileUploads = VisibleIndex + 1;
    Grid_FileUploads_FileUploads.StartEditRowAsync(IndexGrid_FileUploads_FileUploads);
    }
    }
    else if (OpenDialogCodeFileUploads_FileUploads == 0)
    {
        if (VisibleIndex != 0)
        {

            Grid_FileUploads_FileUploads.CancelEditAsync();
            IndexGrid_FileUploads_FileUploads = VisibleIndex - 1;
    Grid_FileUploads_FileUploads.StartEditRowAsync(IndexGrid_FileUploads_FileUploads);
