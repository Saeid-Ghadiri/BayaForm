async void OnYesButtonClickGrid_BaseInfo_Countries ()
{
       if (SelectedItemGrid_BaseInfo_Countries != null)
    {
      if (SelectedItemGrid_BaseInfo_Countries.Id == Guid.Empty)
      {
          var ListEntity = _Entity;
        ListEntity.Remove((Entity.BaseInfo_Countries)SelectedItemGrid_BaseInfo_Countries);
     
      }
      else
      {
        var cleanModel = new Entity.BaseInfo_Countries();
      // چک کن آیا پراپرتی IsDelete در این نوع وجود دارد؟
        var prop = typeof(Entity.BaseInfo_Countries).GetProperty("IsDelete");
        if (prop != null && prop.CanRead && prop.CanWrite)
        {
            // مقدار فعلی را بگیر
            var currentValue = prop.GetValue(SelectedItemGrid_BaseInfo_Countries);

            if (currentValue is bool boolValue)
            {
                // مقدار را معکوس کن
                var newValue = !boolValue;

                // روی هر دو شیء تنظیم کن
                prop.SetValue(SelectedItemGrid_BaseInfo_Countries, newValue);
                prop.SetValue(cleanModel, newValue);
            }
        }
        EntityHelper.SetPropertyValue(cleanModel, cleanModel._GetIdName, SelectedItemGrid_BaseInfo_Countries._Id);
    
      await PostDataDelete(cleanModel); 
       
      }
    }
    var e= SelectedItemGrid_BaseInfo_Countries;
    
    Grid_BaseInfo_Countries.Reload();
    ConfirmationShownBaseInfo_Countries = false;
     await Task.Yield();
    await InvokeAsync(StateHasChanged);

}
