MainModel.BaseInfo_ContinentsId = ((Entity.BaseInfo_Countries)EditModel).BaseInfo_ContinentsId;
MainModel.BaseInfo_Continents = ((Entity.BaseInfo_Countries)EditModel).BaseInfo_Continents;

