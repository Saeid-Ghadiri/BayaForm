async void OnYesButtonClickGrid_ITIL_RequestDetail ()
{
       if (SelectedItemGrid_ITIL_RequestDetail != null)
    {
      if (SelectedItemGrid_ITIL_RequestDetail.Id == Guid.Empty)
      {
          var ListEntity = _Entity.ITIL_RequestDetail;
        ListEntity.Remove((Entity.ITIL_RequestDetail)SelectedItemGrid_ITIL_RequestDetail);
     
      }
      else
      {
        var cleanModel = new Entity.ITIL_RequestDetail();
      // چک کن آیا پراپرتی IsDelete در این نوع وجود دارد؟
        var prop = typeof(Entity.ITIL_RequestDetail).GetProperty("IsDelete");
        if (prop != null && prop.CanRead && prop.CanWrite)
        {
            // مقدار فعلی را بگیر
            var currentValue = prop.GetValue(SelectedItemGrid_ITIL_RequestDetail);

            if (currentValue is bool boolValue)
            {
                // مقدار را معکوس کن
                var newValue = !boolValue;

                // روی هر دو شیء تنظیم کن
                prop.SetValue(SelectedItemGrid_ITIL_RequestDetail, newValue);
                prop.SetValue(cleanModel, newValue);
            }
        }
        EntityHelper.SetPropertyValue(cleanModel, cleanModel._GetIdName, SelectedItemGrid_ITIL_RequestDetail._Id);
    
       
       
      }
    }
    var e= SelectedItemGrid_ITIL_RequestDetail;
    
    Grid_ITIL_RequestDetail.Reload();
    ConfirmationShownITIL_RequestDetail = false;
     await Task.Yield();
    await InvokeAsync(StateHasChanged);

}
