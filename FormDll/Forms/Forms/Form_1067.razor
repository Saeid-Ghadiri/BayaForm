            IndexGrid_ITIL_RequestDetail = VisibleIndex + 1;
    Grid_ITIL_RequestDetail.StartEditRowAsync(IndexGrid_ITIL_RequestDetail);
    }
    }
    else if (OpenDialogCodeITIL_RequestDetail == 0)
    {
        if (VisibleIndex != 0)
        {

            Grid_ITIL_RequestDetail.CancelEditAsync();
            IndexGrid_ITIL_RequestDetail = VisibleIndex - 1;
