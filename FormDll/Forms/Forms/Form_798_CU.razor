async Task ChangePageGrid_HR_RMS_JobHistory()
{
    int VisibleIndex = IndexGrid_HR_RMS_JobHistory;
    try
    {
    if (OpenDialogCodeHR_RMS_JobHistory == 1)
    {
        if (VisibleIndex != (Grid_HR_RMS_JobHistory.GetVisibleRowCount() - 1))
    { 
            Grid_HR_RMS_JobHistory.CancelEditAsync();
            IndexGrid_HR_RMS_JobHistory = VisibleIndex + 1;
    Grid_HR_RMS_JobHistory.StartEditRowAsync(IndexGrid_HR_RMS_JobHistory);
    }
    }
    else if (OpenDialogCodeHR_RMS_JobHistory == 0)
    {
        if (VisibleIndex != 0)
        {

            Grid_HR_RMS_JobHistory.CancelEditAsync();
            IndexGrid_HR_RMS_JobHistory = VisibleIndex - 1;
    Grid_HR_RMS_JobHistory.StartEditRowAsync(IndexGrid_HR_RMS_JobHistory);
    }

    }
    var e = (Entity.HR_RMS_JobHistory)Grid_HR_RMS_JobHistory.GetDataItem(IndexGrid_HR_RMS_JobHistory);
    JsonData = await Utility.JSON.ToJson(e);
    await Task.Delay(300);
    
    StateHasChanged();
    }
    catch (Exception ex)
    {

    Console.WriteLine("error in ChagePage" + ex.Message);
    }

}

