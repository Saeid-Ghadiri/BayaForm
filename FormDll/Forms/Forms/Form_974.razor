async void Dialog_Grid_Shomaran_DepoIn(int _OpenDialogCode, int VisibleIndex, GridEditFormTemplateContext e)
{
    OpenDialogCodeShomaran_DepoIn = _OpenDialogCode;
    if (!CheckChangedData(await Utility.JSON.ToJson(e.EditModel)))
    {
    _ContextFormTemplateShomaran_DepoIn = e;
    ConfirmationShomaran_DepoIn = true;
    }
    else
    {
    await OnNoButtonShomaran_DepoIn();
    }
}
async Task OnYesButtonShomaran_DepoIn()
{

    ConfirmationShomaran_DepoIn = false;
    await Task.Delay(1500);
    //bool FormValidate = await JSO.InvokeAsync<bool>("submitForm");
    bool FormValidate =  await JS.InvokeAsync<bool>("submitForm");
    if (FormValidate)
    {
        bool NotValid = false;
    var e = _ContextFormTemplateShomaran_DepoIn.EditModel;
         //events
         

        if (!NotValid)
         {
        SaveGrid_Shomaran_DepoIn(_ContextFormTemplateShomaran_DepoIn.DataItem, _ContextFormTemplateShomaran_DepoIn.EditModel);
            await Grid_Shomaran_DepoIn.CancelEditAsync();
         await ChangePageGrid_Shomaran_DepoIn();
         await SetEditFormContextGrid_Shomaran_DepoIn();
         }
          
    }

}
async Task OnNoButtonShomaran_DepoIn()
{
    ConfirmationShomaran_DepoIn = false;
    await ChangePageGrid_Shomaran_DepoIn();
    await SetEditFormContextGrid_Shomaran_DepoIn();

}
async Task SetEditFormContextGrid_Shomaran_DepoIn()
{
    var e = (Entity.Shomaran_DepoIn)Grid_Shomaran_DepoIn.GetDataItem(IndexGrid_Shomaran_DepoIn);
    JsonData = await Utility.JSON.ToJson(e);
}

async Task ChangePageGrid_Shomaran_DepoIn()
{
    int VisibleIndex = IndexGrid_Shomaran_DepoIn;
    try
    {
    if (OpenDialogCodeShomaran_DepoIn == 1)
    {
        if (VisibleIndex != (Grid_Shomaran_DepoIn.GetVisibleRowCount() - 1))
    { 
            Grid_Shomaran_DepoIn.CancelEditAsync();
            IndexGrid_Shomaran_DepoIn = VisibleIndex + 1;
    Grid_Shomaran_DepoIn.StartEditRowAsync(IndexGrid_Shomaran_DepoIn);
    }
    }
    else if (OpenDialogCodeShomaran_DepoIn == 0)
    {
        if (VisibleIndex != 0)
        {

            Grid_Shomaran_DepoIn.CancelEditAsync();
            IndexGrid_Shomaran_DepoIn = VisibleIndex - 1;
    Grid_Shomaran_DepoIn.StartEditRowAsync(IndexGrid_Shomaran_DepoIn);
    }

    }
    var e = (Entity.Shomaran_DepoIn)Grid_Shomaran_DepoIn.GetDataItem(IndexGrid_Shomaran_DepoIn);
    JsonData = await Utility.JSON.ToJson(e);
    await Task.Delay(300);
    
    StateHasChanged();
    }
    catch (Exception ex)
    {

    Console.WriteLine("error in ChagePage" + ex.Message);
