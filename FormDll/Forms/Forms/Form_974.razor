    /// <returns></returns>
    public async Task setFocusOff()
    {
        //اگر فوکوس روشن بود خاموشش کن
        if (Grid_Shomaran_DepoIn.FocusedRowEnabled)
    {
            //به علت یروزرسانی دیتاگرید و اینکه فوکوس باید مقدار اولیه داده شود از خط زیر استفاده می شود
            Grid_Shomaran_DepoIn.BeginUpdate();
    Grid_Shomaran_DepoIn.FocusedRowEnabled = false;
    Grid_Shomaran_DepoIn.EndUpdate();
    }

    }
    /// <summary>
    /// فعال کردن فوکوس گرید
    /// </summary>
    /// <returns></returns>
    public async Task setFocusOn()
    {
        if (!Grid_Shomaran_DepoIn.FocusedRowEnabled)
    {
            Grid_Shomaran_DepoIn.BeginUpdate();
    Grid_Shomaran_DepoIn.FocusedRowEnabled = true;

    Grid_Shomaran_DepoIn.EndUpdate();
    }

    }

    public async Task SelectRecord(int PageIndex, int __VisibleIndex)
    {

        isSending = true;
        await setFocusOn();
        PageIndexChanged(PageIndex);
        await ShowFormCU(Grid_Shomaran_DepoIn.GetDataItem(__VisibleIndex));
    DxPager.ActivePageIndex = PageIndex;
        Grid_Shomaran_DepoIn.BeginUpdate();
    Grid_Shomaran_DepoIn.PageIndex = PageIndex;
    Grid_Shomaran_DepoIn.EndUpdate();
    Grid_Shomaran_DepoIn.SetFocusedRowIndex(__VisibleIndex);

    isSending = false;
    }

