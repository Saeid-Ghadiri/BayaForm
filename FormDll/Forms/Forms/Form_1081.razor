    public async Task SelectRecord(int PageIndex, int __VisibleIndex)
    {

        isSending = true;
        await setFocusOn();
        PageIndexChanged(PageIndex);
        await ShowFormCU(Grid_SH_ATLASCELL_DepoIn.GetDataItem(__VisibleIndex));
    DxPager.ActivePageIndex = PageIndex;
        Grid_SH_ATLASCELL_DepoIn.BeginUpdate();
    Grid_SH_ATLASCELL_DepoIn.PageIndex = PageIndex;
    Grid_SH_ATLASCELL_DepoIn.EndUpdate();
    Grid_SH_ATLASCELL_DepoIn.SetFocusedRowIndex(__VisibleIndex);

    isSending = false;
    }

