public void SaveGrid_ITIL_Operation(object DataItem, object EditModel)
{
    var ListEntity = _Entity;
    var MainModel = (Entity.ITIL_Operation)DataItem;
    if (MainModel != null)
    {
MainModel.Id = ((Entity.ITIL_Operation)EditModel).Id;
MainModel.RequestID = ((Entity.ITIL_Operation)EditModel).RequestID;
MainModel.CreateUser = ((Entity.ITIL_Operation)EditModel).CreateUser;
MainModel.UpdateUser = ((Entity.ITIL_Operation)EditModel).UpdateUser;
MainModel.CreateDate = ((Entity.ITIL_Operation)EditModel).CreateDate;
MainModel.UpdateDate = ((Entity.ITIL_Operation)EditModel).UpdateDate;
MainModel.IsDelete = ((Entity.ITIL_Operation)EditModel).IsDelete;
MainModel.Title = ((Entity.ITIL_Operation)EditModel).Title;

    }
    else
    {
    ListEntity.Add((Entity.ITIL_Operation)EditModel);
    }
}

