{
    var e = (Entity.ITIL_Operation)Grid_ITIL_Operation.GetDataItem(IndexGrid_ITIL_Operation);
    JsonData = await Utility.JSON.ToJson(e);
}

async Task ChangePageGrid_ITIL_Operation()
{
    int VisibleIndex = IndexGrid_ITIL_Operation;
    try
    {
    if (OpenDialogCodeITIL_Operation == 1)
    {
        if (VisibleIndex != (Grid_ITIL_Operation.GetVisibleRowCount() - 1))
    { 
            Grid_ITIL_Operation.CancelEditAsync();
            IndexGrid_ITIL_Operation = VisibleIndex + 1;
    Grid_ITIL_Operation.StartEditRowAsync(IndexGrid_ITIL_Operation);
    }
    }
    else if (OpenDialogCodeITIL_Operation == 0)
    {
        if (VisibleIndex != 0)
        {

            Grid_ITIL_Operation.CancelEditAsync();
            IndexGrid_ITIL_Operation = VisibleIndex - 1;
    Grid_ITIL_Operation.StartEditRowAsync(IndexGrid_ITIL_Operation);
    }

    }
    var e = (Entity.ITIL_Operation)Grid_ITIL_Operation.GetDataItem(IndexGrid_ITIL_Operation);
    JsonData = await Utility.JSON.ToJson(e);
    await Task.Delay(300);
    
    StateHasChanged();
    }
    catch (Exception ex)
    {

    Console.WriteLine("error in ChagePage" + ex.Message);
    }

}

