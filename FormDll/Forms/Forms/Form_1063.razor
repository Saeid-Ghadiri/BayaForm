async void OnDeleteButtonClickGrid_ITIL_Operation (GridCommandColumnCellDisplayTemplateContext ex)
{
    SelectedItemGrid_ITIL_Operation = (ex.DataItem as Entity.ITIL_Operation);
    var e =SelectedItemGrid_ITIL_Operation;
    
     
    Console.WriteLine("end OnDeleteButtonClickGrid_test_OrderBody 0");
    ConfirmationShownITIL_Operation = true;
    await Task.Yield();
     await InvokeAsync(StateHasChanged);
    
    Console.WriteLine("end OnDeleteButtonClickGrid_test_OrderBody 1");
}
async void OnYesButtonClickGrid_ITIL_Operation ()
{
       if (SelectedItemGrid_ITIL_Operation != null)
    {
      if (SelectedItemGrid_ITIL_Operation.Id == Guid.Empty)
      {
          var ListEntity = _Entity;
        ListEntity.Remove((Entity.ITIL_Operation)SelectedItemGrid_ITIL_Operation);
     
      }
      else
      {
        var cleanModel = new Entity.ITIL_Operation();
      // چک کن آیا پراپرتی IsDelete در این نوع وجود دارد؟
        var prop = typeof(Entity.ITIL_Operation).GetProperty("IsDelete");
        if (prop != null && prop.CanRead && prop.CanWrite)
        {
            // مقدار فعلی را بگیر
            var currentValue = prop.GetValue(SelectedItemGrid_ITIL_Operation);

            if (currentValue is bool boolValue)
            {
                // مقدار را معکوس کن
                var newValue = !boolValue;

                // روی هر دو شیء تنظیم کن
                prop.SetValue(SelectedItemGrid_ITIL_Operation, newValue);
                prop.SetValue(cleanModel, newValue);
            }
        }
        EntityHelper.SetPropertyValue(cleanModel, cleanModel._GetIdName, SelectedItemGrid_ITIL_Operation._Id);
    
      await PostDataDelete(cleanModel); 
       
      }
    }
    var e= SelectedItemGrid_ITIL_Operation;
    
    Grid_ITIL_Operation.Reload();
    ConfirmationShownITIL_Operation = false;
     await Task.Yield();
    await InvokeAsync(StateHasChanged);

}
void OnNoButtonClickGrid_ITIL_Operation ()
{
    ConfirmationShownITIL_Operation = false;
}

