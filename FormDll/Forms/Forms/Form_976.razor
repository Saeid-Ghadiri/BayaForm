async void OnYesButtonClickGrid_SCMPETCO_SupplierEvaluationModel ()
{
       if (SelectedItemGrid_SCMPETCO_SupplierEvaluationModel != null)
    {
      if (SelectedItemGrid_SCMPETCO_SupplierEvaluationModel.Id == Guid.Empty)
      {
          var ListEntity = _Entity;
        ListEntity.Remove((Entity.SCMPETCO_SupplierEvaluationModel)SelectedItemGrid_SCMPETCO_SupplierEvaluationModel);
     
      }
      else
      {
        var cleanModel = new Entity.SCMPETCO_SupplierEvaluationModel();
      // چک کن آیا پراپرتی IsDelete در این نوع وجود دارد؟
        var prop = typeof(Entity.SCMPETCO_SupplierEvaluationModel).GetProperty("IsDelete");
        if (prop != null && prop.CanRead && prop.CanWrite)
        {
            // مقدار فعلی را بگیر
            var currentValue = prop.GetValue(SelectedItemGrid_SCMPETCO_SupplierEvaluationModel);

            if (currentValue is bool boolValue)
            {
                // مقدار را معکوس کن
                var newValue = !boolValue;

                // روی هر دو شیء تنظیم کن
                prop.SetValue(SelectedItemGrid_SCMPETCO_SupplierEvaluationModel, newValue);
                prop.SetValue(cleanModel, newValue);
            }
        }
        EntityHelper.SetPropertyValue(cleanModel, cleanModel._GetIdName, SelectedItemGrid_SCMPETCO_SupplierEvaluationModel._Id);
    
      await PostDataDelete(cleanModel); 
       
      }
    }
    var e= SelectedItemGrid_SCMPETCO_SupplierEvaluationModel;
    
    Grid_SCMPETCO_SupplierEvaluationModel.Reload();
    ConfirmationShownSCMPETCO_SupplierEvaluationModel = false;
     await Task.Yield();
    await InvokeAsync(StateHasChanged);

}
