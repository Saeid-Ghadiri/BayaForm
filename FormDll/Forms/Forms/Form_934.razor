async Task ChangePageGrid_HR_BankAccounts()
{
    int VisibleIndex = IndexGrid_HR_BankAccounts;
    try
    {
    if (OpenDialogCodeHR_BankAccounts == 1)
    {
        if (VisibleIndex != (Grid_HR_BankAccounts.GetVisibleRowCount() - 1))
    { 
            Grid_HR_BankAccounts.CancelEditAsync();
            IndexGrid_HR_BankAccounts = VisibleIndex + 1;
    Grid_HR_BankAccounts.StartEditRowAsync(IndexGrid_HR_BankAccounts);
    }
    }
    else if (OpenDialogCodeHR_BankAccounts == 0)
    {
        if (VisibleIndex != 0)
        {

            Grid_HR_BankAccounts.CancelEditAsync();
            IndexGrid_HR_BankAccounts = VisibleIndex - 1;
    Grid_HR_BankAccounts.StartEditRowAsync(IndexGrid_HR_BankAccounts);
    }

    }
    var e = (Entity.HR_BankAccounts)Grid_HR_BankAccounts.GetDataItem(IndexGrid_HR_BankAccounts);
    JsonData = await Utility.JSON.ToJson(e);
    await Task.Delay(300);
    
    StateHasChanged();
    }
    catch (Exception ex)
    {

    Console.WriteLine("error in ChagePage" + ex.Message);
    }

}

