async void OnYesButtonClickGrid_HR_BankAccounts ()
{
       if (SelectedItemGrid_HR_BankAccounts != null)
    {
      if (SelectedItemGrid_HR_BankAccounts.Id == Guid.Empty)
      {
          var ListEntity = _Entity;
        ListEntity.Remove((Entity.HR_BankAccounts)SelectedItemGrid_HR_BankAccounts);
     
      }
      else
      {
        var cleanModel = new Entity.HR_BankAccounts();
      // چک کن آیا پراپرتی IsDelete در این نوع وجود دارد؟
        var prop = typeof(Entity.HR_BankAccounts).GetProperty("IsDelete");
        if (prop != null && prop.CanRead && prop.CanWrite)
        {
            // مقدار فعلی را بگیر
            var currentValue = prop.GetValue(SelectedItemGrid_HR_BankAccounts);

            if (currentValue is bool boolValue)
            {
                // مقدار را معکوس کن
                var newValue = !boolValue;

                // روی هر دو شیء تنظیم کن
                prop.SetValue(SelectedItemGrid_HR_BankAccounts, newValue);
                prop.SetValue(cleanModel, newValue);
            }
        }
        EntityHelper.SetPropertyValue(cleanModel, cleanModel._GetIdName, SelectedItemGrid_HR_BankAccounts._Id);
    
      await PostDataDelete(cleanModel); 
       
      }
    }
    var e= SelectedItemGrid_HR_BankAccounts;
    
    Grid_HR_BankAccounts.Reload();
    ConfirmationShownHR_BankAccounts = false;
     await Task.Yield();
    await InvokeAsync(StateHasChanged);

}
