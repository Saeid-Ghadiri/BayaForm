async void OnYesButtonClickGrid_SH_Petco_DepoOut ()
{
       if (SelectedItemGrid_SH_Petco_DepoOut != null)
    {
      if (SelectedItemGrid_SH_Petco_DepoOut.Id == Guid.Empty)
      {
          var ListEntity = _Entity;
        ListEntity.Remove((Entity.SH_Petco_DepoOut)SelectedItemGrid_SH_Petco_DepoOut);
     
      }
      else
      {
        var cleanModel = new Entity.SH_Petco_DepoOut();
      // چک کن آیا پراپرتی IsDelete در این نوع وجود دارد؟
        var prop = typeof(Entity.SH_Petco_DepoOut).GetProperty("IsDelete");
        if (prop != null && prop.CanRead && prop.CanWrite)
        {
            // مقدار فعلی را بگیر
            var currentValue = prop.GetValue(SelectedItemGrid_SH_Petco_DepoOut);

            if (currentValue is bool boolValue)
            {
                // مقدار را معکوس کن
                var newValue = !boolValue;

                // روی هر دو شیء تنظیم کن
                prop.SetValue(SelectedItemGrid_SH_Petco_DepoOut, newValue);
                prop.SetValue(cleanModel, newValue);
            }
        }
        EntityHelper.SetPropertyValue(cleanModel, cleanModel._GetIdName, SelectedItemGrid_SH_Petco_DepoOut._Id);
    
      await PostDataDelete(cleanModel); 
       
      }
    }
    var e= SelectedItemGrid_SH_Petco_DepoOut;
    
    Grid_SH_Petco_DepoOut.Reload();
    ConfirmationShownSH_Petco_DepoOut = false;
     await Task.Yield();
    await InvokeAsync(StateHasChanged);

