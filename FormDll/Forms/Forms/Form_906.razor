    public async Task setFocusOn()
    {
        if (!Grid_Shomaran_ProductDelivery.FocusedRowEnabled)
    {
            Grid_Shomaran_ProductDelivery.BeginUpdate();
    Grid_Shomaran_ProductDelivery.FocusedRowEnabled = true;

    Grid_Shomaran_ProductDelivery.EndUpdate();
    }

    }

    public async Task SelectRecord(int PageIndex, int __VisibleIndex)
    {

        isSending = true;
        await setFocusOn();
        PageIndexChanged(PageIndex);
        await ShowFormCU(Grid_Shomaran_ProductDelivery.GetDataItem(__VisibleIndex));
    DxPager.ActivePageIndex = PageIndex;
        Grid_Shomaran_ProductDelivery.BeginUpdate();
    Grid_Shomaran_ProductDelivery.PageIndex = PageIndex;
    Grid_Shomaran_ProductDelivery.EndUpdate();
    Grid_Shomaran_ProductDelivery.SetFocusedRowIndex(__VisibleIndex);

    isSending = false;
    }

