async Task ChangePageGrid_Shomaran_ProductDelivery()
{
    int VisibleIndex = IndexGrid_Shomaran_ProductDelivery;
    try
    {
    if (OpenDialogCodeShomaran_ProductDelivery == 1)
    {
        if (VisibleIndex != (Grid_Shomaran_ProductDelivery.GetVisibleRowCount() - 1))
    { 
            Grid_Shomaran_ProductDelivery.CancelEditAsync();
            IndexGrid_Shomaran_ProductDelivery = VisibleIndex + 1;
    Grid_Shomaran_ProductDelivery.StartEditRowAsync(IndexGrid_Shomaran_ProductDelivery);
    }
    }
    else if (OpenDialogCodeShomaran_ProductDelivery == 0)
    {
        if (VisibleIndex != 0)
        {

            Grid_Shomaran_ProductDelivery.CancelEditAsync();
            IndexGrid_Shomaran_ProductDelivery = VisibleIndex - 1;
    Grid_Shomaran_ProductDelivery.StartEditRowAsync(IndexGrid_Shomaran_ProductDelivery);
    }

    }
    var e = (Entity.Shomaran_ProductDelivery)Grid_Shomaran_ProductDelivery.GetDataItem(IndexGrid_Shomaran_ProductDelivery);
    JsonData = await Utility.JSON.ToJson(e);
    await Task.Delay(300);
    
    StateHasChanged();
    }
    catch (Exception ex)
    {

    Console.WriteLine("error in ChagePage" + ex.Message);
    }

}

