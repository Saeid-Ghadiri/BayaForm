.info-red { background: #ffebee; color: #c62828; }
.info-green { background: #f1f8e9; color: #2e7d32; }
.info-purple { background: #f3e5f5; color: #4a148c; }

/* ========================================
   Step Notes
   ======================================== */
.step-note {
