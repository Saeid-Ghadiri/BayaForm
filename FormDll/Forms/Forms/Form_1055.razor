<style>
    .fishMainCard {
    background: var(--white);
    border-radius: 0.6rem;
    box-shadow: 0 2px 30px #0000000f;
    padding: 1.5rem;
    margin-top: 1rem;
}

.itemOld {
    color: var(--red) !important;
    background: linear-gradient(90deg, #e826460f, transparent);
}

.itemNew {
    color: #1a9a4a !important;
    background: linear-gradient(270deg, #29b39c17, transparent);
}

/* ************************************************** */
.itemSpaceInput {
    display: inline-flex;
    width: 100%;
    justify-content: space-between;
    border: 1px solid #e9edf4;
    align-items: baseline;
    padding-right: 10px;
    border-top: 0;
}

.itemSpaceInput label {
    font-size: 14px;
}

.itemSpaceInput.input-string input {
    border-radius: 0;
    border-width: 0 1px 0 0 !important;
    border: 1px solid #e9edf4;
}

.input-string input {
    display: inline-block;
    max-width: 260px !important;
    background: none !important;
    border: none;
    text-align: start !important;
    font-size: 14px;
    font-weight: bold;
}

.btnShowFish.btn {
    background: var(--purple);
    color: #fff;
    transition: all ease-out 0.5s;
    border: none;
}

.btnShowFish.btn:hover {
    color: var(--darkblue) !important;
    box-shadow: inset 25rem 0 0 0 var(--lightpurple), 0 2px 10px #0000001f;
}

/* ************************************************** */
/*  تنظیمات کلی دکمه چاپ */
.print-btn-container {
    padding-top: 1rem;
    display: inline-block;
}

.print-btn {
    position: relative;
    padding: 6px 6px;
    border: none;
    border-radius: 6px;
    background: linear-gradient(135deg, #4361ee, #3a0ca3);
    color: white;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    overflow: hidden;
    transition: all 0.3s ease;
    box-shadow: 0 4px 8px rgba(67, 97, 238, 0.2);
    display: flex;
    align-items: center;
    gap: 10px;
}

/* افکت های تعاملی */
.print-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 12px rgba(67, 97, 238, 0.3);
    background: linear-gradient(135deg, #4895ef, #4361ee);
}

.print-btn:active {
    transform: translateY(0);
    box-shadow: 0 2px 4px rgba(67, 97, 238, 0.2);
}

/* استایل آیکون */
.print-icon {
    display: flex;
    align-items: center;
    transition: transform 0.3s ease;
}

.print-btn:hover .print-icon {
    transform: translateX(3px);
}

/* افکت موجی هنگام کلیک */
.print-wave {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.6) 10%, transparent 10.01%) no-repeat 50%;
    transform: scale(10, 10);
    opacity: 0;
    transition: transform 0.5s, opacity 1s;
    pointer-events: none;
}

.print-btn:active .print-wave {
    transform: scale(0, 0);
    opacity: 0.4;
    transition: 0s;
}

/* ************************************************** */

@@media print {
    body {
        padding-top: 3px;
        font-size: 12px !important;
        font-weight: bold;
        line-height: 1.2 !important;
        color: #000 !important;
        background: none !important;
    }

    main {
        height: unset !important;
        min-height: unset !important;
        max-height: unset !important;
    }

    .dxbl-grid-table th,
    .dxbl-grid-table td {
        font-size: 12px !important;
        font-weight: bold;
        color: #000 !important;
    }

    h1 {
        font-size: 18px !important;
    }

    h2 {
        font-size: 16px !important;
    }

    h3 {
        font-size: 14px !important;
    }

    a {
        color: #000 !important;
        text-decoration: underline !important;
    }

    /* ستون 1 و 3 نمایش داده نشود در پرینت */
    table tr>*:nth-child(1),
    table tr>*:nth-child(3) {
        display: none;
    }

    /* از ستون 9 به بعد نمایش داده نشود در پرینت */
    table tr>*:nth-child(n+9) {
        display: none;
    }

    .fishMainCard {
        margin: 0;
        box-shadow: none;
        padding: 0;
    }

    .input-string label {
        font-size: 10px !important;

    }

    .input-string input {
        font-size: 12px !important;
        width: auto;
    }

    @@media (max-width: 768px) {
        .col-md-6 {
            flex: 0 0 auto;
            width: 50%;
        }

        .col-md-4 {
            flex: 0 0 auto;
            width: 33.33333333%;
        }

        .col-md-3 {
            flex: 0 0 auto;
            width: 25%;
        }
    }
}
</style>

