 <div class="print-btn-container">
    <button type="button" onclick="customPrint()" class="print-btn">
        <span class="print-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                <path d="M5 1a2 2 0 0 0-2 2v1h10V3a2 2 0 0 0-2-2H5zm6 8H5a1 1 0 0 0-1 1v3a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1v-3a1 1 0 0 0-1-1z"/>
                <path d="M0 7a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2h-1v-2a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v2H2a2 2 0 0 1-2-2V7zm2.5 1a.5.5 0 1 0 0-1 .5.5 0 0 0 0 1z"/>
            </svg>
        </span>
        <span class="print-text">چاپ</span>
        <span class="print-wave"></span>
    </button>
</div>


<script>
function customPrint() {
    // لیست تمام عناصری که می‌خواهید مخفی شوند
    const elementsToHide = [
        '#submit',                  //دکمه نمایش فیش حقوقی
        '.sideArea',                // نوار کناری
        '.toprow.sticky-top',       // نوار بالایی
        '.no-print',                // عناصر با کلاس no-print
        '.btn-back',                // دکمه برگشت
        '.print-btn-container',     // دکمه چاپ در صفحه
        '.logo',                    // لوگو
        '.formTitle',               // تایتل صفحه
        '.formCode',                // کد فرم بالای صفحه فرم
        '.tab_Info',                // مخفی کردن تب های اطلاعاتی
        '.footer'                   // فوتر
    ];
    
    // ذخیره وضعیت اصلی و مخفی کردن
    const hiddenElements = [];
    
    elementsToHide.forEach(selector => {
        const elements = document.querySelectorAll(selector);
        elements.forEach(el => {
            hiddenElements.push({
                element: el,
                originalDisplay: el.style.display
            });
            //el.style.display = 'none';
            $(el).addClass("d-print-none");
        });
    });
    
    // چاپ صفحه
    window.print();
    
    // بازگرداندن عناصر پس از چاپ
    // setTimeout(() => {
    //     hiddenElements.forEach(item => {
    //         item.element.style.display = item.originalDisplay || '';
