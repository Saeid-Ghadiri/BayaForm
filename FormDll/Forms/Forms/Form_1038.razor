public void SaveGrid_Notifications_Category(object DataItem, object EditModel)
{
    var ListEntity = _Entity;
    var MainModel = (Entity.Notifications_Category)DataItem;
    if (MainModel != null)
    {
MainModel.Id = ((Entity.Notifications_Category)EditModel).Id;
MainModel.RequestID = ((Entity.Notifications_Category)EditModel).RequestID;
MainModel.CreateUser = ((Entity.Notifications_Category)EditModel).CreateUser;
MainModel.UpdateUser = ((Entity.Notifications_Category)EditModel).UpdateUser;
MainModel.CreateDate = ((Entity.Notifications_Category)EditModel).CreateDate;
MainModel.UpdateDate = ((Entity.Notifications_Category)EditModel).UpdateDate;
MainModel.IsDelete = ((Entity.Notifications_Category)EditModel).IsDelete;
MainModel.Title = ((Entity.Notifications_Category)EditModel).Title;
MainModel.Code = ((Entity.Notifications_Category)EditModel).Code;

    }
    else
    {
    ListEntity.Add((Entity.Notifications_Category)EditModel);
    }
}

