async void OnYesButtonClickGrid_Notifications_Category ()
{
       if (SelectedItemGrid_Notifications_Category != null)
    {
      if (SelectedItemGrid_Notifications_Category.Id == Guid.Empty)
      {
          var ListEntity = _Entity;
        ListEntity.Remove((Entity.Notifications_Category)SelectedItemGrid_Notifications_Category);
     
      }
      else
      {
        var cleanModel = new Entity.Notifications_Category();
      // چک کن آیا پراپرتی IsDelete در این نوع وجود دارد؟
        var prop = typeof(Entity.Notifications_Category).GetProperty("IsDelete");
        if (prop != null && prop.CanRead && prop.CanWrite)
        {
            // مقدار فعلی را بگیر
            var currentValue = prop.GetValue(SelectedItemGrid_Notifications_Category);

            if (currentValue is bool boolValue)
            {
                // مقدار را معکوس کن
                var newValue = !boolValue;

                // روی هر دو شیء تنظیم کن
                prop.SetValue(SelectedItemGrid_Notifications_Category, newValue);
                prop.SetValue(cleanModel, newValue);
            }
        }
        EntityHelper.SetPropertyValue(cleanModel, cleanModel._GetIdName, SelectedItemGrid_Notifications_Category._Id);
    
      await PostDataDelete(cleanModel); 
       
      }
    }
    var e= SelectedItemGrid_Notifications_Category;
    
    Grid_Notifications_Category.Reload();
    ConfirmationShownNotifications_Category = false;
     await Task.Yield();
    await InvokeAsync(StateHasChanged);

}
void OnNoButtonClickGrid_Notifications_Category ()
{
    ConfirmationShownNotifications_Category = false;
}

