async void OnYesButtonClickGrid_Shomaran_FiscalYear ()
{
       if (SelectedItemGrid_Shomaran_FiscalYear != null)
    {
      if (SelectedItemGrid_Shomaran_FiscalYear.Id == Guid.Empty)
      {
          var ListEntity = _Entity;
        ListEntity.Remove((Entity.Shomaran_FiscalYear)SelectedItemGrid_Shomaran_FiscalYear);
     
      }
      else
      {
        var cleanModel = new Entity.Shomaran_FiscalYear();
      // چک کن آیا پراپرتی IsDelete در این نوع وجود دارد؟
        var prop = typeof(Entity.Shomaran_FiscalYear).GetProperty("IsDelete");
        if (prop != null && prop.CanRead && prop.CanWrite)
        {
            // مقدار فعلی را بگیر
            var currentValue = prop.GetValue(SelectedItemGrid_Shomaran_FiscalYear);

            if (currentValue is bool boolValue)
            {
                // مقدار را معکوس کن
                var newValue = !boolValue;

                // روی هر دو شیء تنظیم کن
                prop.SetValue(SelectedItemGrid_Shomaran_FiscalYear, newValue);
                prop.SetValue(cleanModel, newValue);
            }
        }
        EntityHelper.SetPropertyValue(cleanModel, cleanModel._GetIdName, SelectedItemGrid_Shomaran_FiscalYear._Id);
    
      await PostDataDelete(cleanModel); 
       
      }
    }
    var e= SelectedItemGrid_Shomaran_FiscalYear;
    
    Grid_Shomaran_FiscalYear.Reload();
    ConfirmationShownShomaran_FiscalYear = false;
     await Task.Yield();
    await InvokeAsync(StateHasChanged);

}
