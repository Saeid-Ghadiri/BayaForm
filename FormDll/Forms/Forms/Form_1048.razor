public void SaveGrid_SCMNFP_FileUpload(object DataItem, object EditModel)
{
    var ListEntity = _Entity;
    var MainModel = (Entity.SCMNFP_FileUpload)DataItem;
    if (MainModel != null)
    {
MainModel.Id = ((Entity.SCMNFP_FileUpload)EditModel).Id;
MainModel.RequestID = ((Entity.SCMNFP_FileUpload)EditModel).RequestID;
MainModel.CreateUser = ((Entity.SCMNFP_FileUpload)EditModel).CreateUser;
MainModel.UpdateUser = ((Entity.SCMNFP_FileUpload)EditModel).UpdateUser;
MainModel.CreateDate = ((Entity.SCMNFP_FileUpload)EditModel).CreateDate;
MainModel.UpdateDate = ((Entity.SCMNFP_FileUpload)EditModel).UpdateDate;
MainModel.IsDelete = ((Entity.SCMNFP_FileUpload)EditModel).IsDelete;
MainModel.Title = ((Entity.SCMNFP_FileUpload)EditModel).Title;
MainModel.Counter = ((Entity.SCMNFP_FileUpload)EditModel).Counter;

    }
    else
    {
    ListEntity.Add((Entity.SCMNFP_FileUpload)EditModel);
    }
}

