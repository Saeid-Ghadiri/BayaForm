async void OnYesButtonClickGrid_SCMNFP_FileUpload ()
{
       if (SelectedItemGrid_SCMNFP_FileUpload != null)
    {
      if (SelectedItemGrid_SCMNFP_FileUpload.Id == Guid.Empty)
      {
          var ListEntity = _Entity;
        ListEntity.Remove((Entity.SCMNFP_FileUpload)SelectedItemGrid_SCMNFP_FileUpload);
     
      }
      else
      {
        var cleanModel = new Entity.SCMNFP_FileUpload();
      // چک کن آیا پراپرتی IsDelete در این نوع وجود دارد؟
        var prop = typeof(Entity.SCMNFP_FileUpload).GetProperty("IsDelete");
        if (prop != null && prop.CanRead && prop.CanWrite)
        {
            // مقدار فعلی را بگیر
            var currentValue = prop.GetValue(SelectedItemGrid_SCMNFP_FileUpload);

            if (currentValue is bool boolValue)
            {
                // مقدار را معکوس کن
                var newValue = !boolValue;

                // روی هر دو شیء تنظیم کن
                prop.SetValue(SelectedItemGrid_SCMNFP_FileUpload, newValue);
                prop.SetValue(cleanModel, newValue);
            }
        }
        EntityHelper.SetPropertyValue(cleanModel, cleanModel._GetIdName, SelectedItemGrid_SCMNFP_FileUpload._Id);
    
      await PostDataDelete(cleanModel); 
       
      }
    }
    var e= SelectedItemGrid_SCMNFP_FileUpload;
    
    Grid_SCMNFP_FileUpload.Reload();
    ConfirmationShownSCMNFP_FileUpload = false;
     await Task.Yield();
    await InvokeAsync(StateHasChanged);

}
