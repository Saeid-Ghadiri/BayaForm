async Task ChangePageGrid_Global_PHB_Main()
{
    int VisibleIndex = IndexGrid_Global_PHB_Main;
    try
    {
    if (OpenDialogCodeGlobal_PHB_Main == 1)
    {
        if (VisibleIndex != (Grid_Global_PHB_Main.GetVisibleRowCount() - 1))
    { 
            Grid_Global_PHB_Main.CancelEditAsync();
            IndexGrid_Global_PHB_Main = VisibleIndex + 1;
    Grid_Global_PHB_Main.StartEditRowAsync(IndexGrid_Global_PHB_Main);
    }
    }
    else if (OpenDialogCodeGlobal_PHB_Main == 0)
    {
        if (VisibleIndex != 0)
        {

            Grid_Global_PHB_Main.CancelEditAsync();
            IndexGrid_Global_PHB_Main = VisibleIndex - 1;
    Grid_Global_PHB_Main.StartEditRowAsync(IndexGrid_Global_PHB_Main);
    }

    }
    var e = (Entity.Global_PHB_Main)Grid_Global_PHB_Main.GetDataItem(IndexGrid_Global_PHB_Main);
    JsonData = await Utility.JSON.ToJson(e);
    await Task.Delay(300);
    
