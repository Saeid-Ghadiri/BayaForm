    public int IndexGrid_HR_EMP_Employees { get; set; }

    ///////////////////////
    bool ConfirmationHR_EMP_Employees { get; set; } = false;
    GridEditFormTemplateContext? _ContextFormTemplateHR_EMP_Employees { get; set; }
    public int OpenDialogCodeHR_EMP_Employees { get; set; } = 0;
    ////////////////////////

    async Task OnEditModelSavingHR_EMP_Employees(GridEditModelSavingEventArgs arg)
    {
        var e = arg.EditModel;
    bool NotValid = false;
    //events
       
        
      if (!NotValid)
     {
      SaveGrid_HR_EMP_Employees(arg.DataItem, arg.EditModel);
     }
}

async void Dialog_Grid_HR_EMP_Employees(int _OpenDialogCode, int VisibleIndex, GridEditFormTemplateContext e)
{
    OpenDialogCodeHR_EMP_Employees = _OpenDialogCode;
    if (!CheckChangedData(await Utility.JSON.ToJson(e.EditModel)))
    {
    _ContextFormTemplateHR_EMP_Employees = e;
    ConfirmationHR_EMP_Employees = true;
    }
    else
    {
    await OnNoButtonHR_EMP_Employees();
    }
}
async Task OnYesButtonHR_EMP_Employees()
{

    ConfirmationHR_EMP_Employees = false;
    await Task.Delay(1500);
    //bool FormValidate = await JSO.InvokeAsync<bool>("submitForm");
    bool FormValidate =  await JS.InvokeAsync<bool>("submitForm");
    if (FormValidate)
    {
        bool NotValid = false;
    var e = _ContextFormTemplateHR_EMP_Employees.EditModel;
         //events
         

        if (!NotValid)
         {
        SaveGrid_HR_EMP_Employees(_ContextFormTemplateHR_EMP_Employees.DataItem, _ContextFormTemplateHR_EMP_Employees.EditModel);
            await Grid_HR_EMP_Employees.CancelEditAsync();
         await ChangePageGrid_HR_EMP_Employees();
         await SetEditFormContextGrid_HR_EMP_Employees();
         }
          
    }

}
async Task OnNoButtonHR_EMP_Employees()
{
    ConfirmationHR_EMP_Employees = false;
    await ChangePageGrid_HR_EMP_Employees();
    await SetEditFormContextGrid_HR_EMP_Employees();

}
async Task SetEditFormContextGrid_HR_EMP_Employees()
{
    var e = (Entity.HR_EMP_Employees)Grid_HR_EMP_Employees.GetDataItem(IndexGrid_HR_EMP_Employees);
    JsonData = await Utility.JSON.ToJson(e);
}

async Task ChangePageGrid_HR_EMP_Employees()
{
    int VisibleIndex = IndexGrid_HR_EMP_Employees;
    try
    {
    if (OpenDialogCodeHR_EMP_Employees == 1)
    {
        if (VisibleIndex != (Grid_HR_EMP_Employees.GetVisibleRowCount() - 1))
    { 
            Grid_HR_EMP_Employees.CancelEditAsync();
            IndexGrid_HR_EMP_Employees = VisibleIndex + 1;
    Grid_HR_EMP_Employees.StartEditRowAsync(IndexGrid_HR_EMP_Employees);
    }
    }
    else if (OpenDialogCodeHR_EMP_Employees == 0)
    {
        if (VisibleIndex != 0)
        {

            Grid_HR_EMP_Employees.CancelEditAsync();
            IndexGrid_HR_EMP_Employees = VisibleIndex - 1;
    Grid_HR_EMP_Employees.StartEditRowAsync(IndexGrid_HR_EMP_Employees);
    }

    }
    var e = (Entity.HR_EMP_Employees)Grid_HR_EMP_Employees.GetDataItem(IndexGrid_HR_EMP_Employees);
    JsonData = await Utility.JSON.ToJson(e);
    await Task.Delay(300);
    
    StateHasChanged();
    }
    catch (Exception ex)
    {

    Console.WriteLine("error in ChagePage" + ex.Message);
    }

}

async Task StartEditNewRowAsync_Grid_HR_EMP_Employees()
{
    //تعداد سطرهای کل
_VisibleIndex = Grid_HR_EMP_Employees.GetVisibleRowCount();
setFocusOff();
