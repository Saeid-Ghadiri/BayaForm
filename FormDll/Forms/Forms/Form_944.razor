    /// </summary>
    /// <returns></returns>
    public async Task setFocusOff()
    {
        //اگر فوکوس روشن بود خاموشش کن
        if (Grid_HR_EMP_Employees.FocusedRowEnabled)
    {
            //به علت یروزرسانی دیتاگرید و اینکه فوکوس باید مقدار اولیه داده شود از خط زیر استفاده می شود
            Grid_HR_EMP_Employees.BeginUpdate();
    Grid_HR_EMP_Employees.FocusedRowEnabled = false;
    Grid_HR_EMP_Employees.EndUpdate();
    }

    }
    /// <summary>
    /// فعال کردن فوکوس گرید
    /// </summary>
    /// <returns></returns>
    public async Task setFocusOn()
    {
        if (!Grid_HR_EMP_Employees.FocusedRowEnabled)
    {
            Grid_HR_EMP_Employees.BeginUpdate();
    Grid_HR_EMP_Employees.FocusedRowEnabled = true;

    Grid_HR_EMP_Employees.EndUpdate();
    }

    }

    public async Task SelectRecord(int PageIndex, int __VisibleIndex)
    {

        isSending = true;
        await setFocusOn();
        PageIndexChanged(PageIndex);
        await ShowFormCU(Grid_HR_EMP_Employees.GetDataItem(__VisibleIndex));
    DxPager.ActivePageIndex = PageIndex;
        Grid_HR_EMP_Employees.BeginUpdate();
    Grid_HR_EMP_Employees.PageIndex = PageIndex;
    Grid_HR_EMP_Employees.EndUpdate();
    Grid_HR_EMP_Employees.SetFocusedRowIndex(__VisibleIndex);

    isSending = false;
    }

    public async Task SetPageIndex(int Index)
    {
