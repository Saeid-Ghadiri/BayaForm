    Grid_HR_CVR_PersonnelContract.FocusedRowEnabled = true;

    Grid_HR_CVR_PersonnelContract.EndUpdate();
    }

    }

    public async Task SelectRecord(int PageIndex, int __VisibleIndex)
    {

        isSending = true;
        await setFocusOn();
        PageIndexChanged(PageIndex);
        await ShowFormCU(Grid_HR_CVR_PersonnelContract.GetDataItem(__VisibleIndex));
    DxPager.ActivePageIndex = PageIndex;
        Grid_HR_CVR_PersonnelContract.BeginUpdate();
    Grid_HR_CVR_PersonnelContract.PageIndex = PageIndex;
    Grid_HR_CVR_PersonnelContract.EndUpdate();
    Grid_HR_CVR_PersonnelContract.SetFocusedRowIndex(__VisibleIndex);

    isSending = false;
    }

