async void OnYesButtonClickGrid_HR_StatusRecruitmentHiring ()
{
       if (SelectedItemGrid_HR_StatusRecruitmentHiring != null)
    {
      if (SelectedItemGrid_HR_StatusRecruitmentHiring.Id == Guid.Empty)
      {
          var ListEntity = _Entity;
        ListEntity.Remove((Entity.HR_StatusRecruitmentHiring)SelectedItemGrid_HR_StatusRecruitmentHiring);
     
      }
      else
      {
        var cleanModel = new Entity.HR_StatusRecruitmentHiring();
      // چک کن آیا پراپرتی IsDelete در این نوع وجود دارد؟
        var prop = typeof(Entity.HR_StatusRecruitmentHiring).GetProperty("IsDelete");
        if (prop != null && prop.CanRead && prop.CanWrite)
        {
            // مقدار فعلی را بگیر
            var currentValue = prop.GetValue(SelectedItemGrid_HR_StatusRecruitmentHiring);

            if (currentValue is bool boolValue)
            {
                // مقدار را معکوس کن
                var newValue = !boolValue;

                // روی هر دو شیء تنظیم کن
                prop.SetValue(SelectedItemGrid_HR_StatusRecruitmentHiring, newValue);
                prop.SetValue(cleanModel, newValue);
            }
        }
        EntityHelper.SetPropertyValue(cleanModel, cleanModel._GetIdName, SelectedItemGrid_HR_StatusRecruitmentHiring._Id);
    
      await PostDataDelete(cleanModel); 
       
      }
    }
    var e= SelectedItemGrid_HR_StatusRecruitmentHiring;
    
    Grid_HR_StatusRecruitmentHiring.Reload();
    ConfirmationShownHR_StatusRecruitmentHiring = false;
     await Task.Yield();
    await InvokeAsync(StateHasChanged);

}
