<style>
    /* ************************************************** */
.detailArea form div:not(.devdrop) {
    margin-top: .1rem;
}

/* ************************************************** */
.col-bg0 {
    background: #93b0ff0d;
    border: 1px dashed #6c5ffc45;
    border-radius: 8px;
    padding-top: 0.5rem;
    padding-bottom: 0.5rem;
    margin-right: 0;
    margin-left: 0;
}

.col-bg1 {
    background: rgba(250, 250, 255, 0.8);
    /* سفید مایل به آبی خیلی روشن */
    border: 1px solid rgba(230, 240, 255, 0.9);
    border-radius: 8px;
    padding-top: 0.5rem;
    padding-bottom: 0.5rem;
    margin-right: 0;
    margin-left: 0;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.1);
}

.col-bg1:hover {
    background: rgba(74, 158, 240, 0.08);
    /* آبی خیلی خیلی شفاف */
    border: 1px solid rgba(74, 158, 240, 0.2);
    cursor: pointer;
    transform: translateY(-1px);
}

.col-bg2 {
    background: rgba(255, 250, 255, 0.8);
    /* سفید مایل به بنفش خیلی روشن */
    border: 1px solid rgba(245, 240, 255, 0.9);
    border-radius: 8px;
    padding-top: 0.5rem;
    padding-bottom: 0.5rem;
    margin-right: 0;
    margin-left: 0;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.1);
}

.col-bg2:hover {
    background: rgba(122, 90, 248, 0.08);
    /* بنفش خیلی خیلی شفاف */
    border: 1px solid rgba(122, 90, 248, 0.2);
    cursor: pointer;
    transform: translateY(-1px);
}

/* ************************************************** */

.form-header {
    background: linear-gradient(to bottom, #6c5ffc, #0d1a52);
    color: white;
    padding: 1.5rem 2rem;
    border-radius: 0.5rem 0.5rem 0 0;
    margin-bottom: 0;
    position: relative;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
    transition: all 0.3s ease;
}

.form-header:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 25px rgba(0, 0, 0, 0.2);
}

.form-header h2 {
    font-weight: 700;
    margin-bottom: 0;
    display: flex;
    align-items: center;
    position: relative;
    z-index: 2;
}

.form-header .icon {
    font-size: 1.8rem;
    margin-left: 15px;
    animation: float 3s ease-in-out infinite;
}

.form-header::before {
    content: "";
    position: absolute;
    top: -50%;
    right: -50%;
    width: 200%;
    height: 200%;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, rgba(255, 255, 255, 0) 70%);
    transform: rotate(45deg);
    z-index: 1;
    transition: all 0.5s ease;
}

.form-header:hover::before {
    transform: rotate(45deg) translate(20px, 20px);
}

.form-header .decoration {
    position: absolute;
    width: 100px;
    height: 100px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.05);
    z-index: 1;
}

.form-header .decoration-1 {
    top: -30px;
    left: -30px;
    width: 120px;
    height: 120px;
}

.form-header .decoration-2 {
    bottom: -40px;
    right: -20px;
    width: 80px;
    height: 80px;
}

@@keyframes float {
    0% {
        transform: translateY(0px);
    }

    50% {
        transform: translateY(-5px);
    }

    100% {
        transform: translateY(0px);
    }
}

@@keyframes pulse {
    0% {
        opacity: 0.3;
    }

    50% {
        opacity: 0.1;
    }

    100% {
        opacity: 0.3;
    }
}

.pulse-animation {
    animation: pulse 4s ease-in-out infinite;
}

/* ************************************************** */
.input-ymd input {
    display: inline-block;
    max-width: 120px !important;
    background: none !important;
    border: none;
    color: #6c5ffc;
    font-size: 20px;
    text-align: center;
    font-weight: 750;
}

.input-int input {
    display: inline-block;
    max-width: 170px !important;
    background: none !important;
    border: none;
    color: #2e1bff8e;
    font-size: 18px;
    text-align: center;
    font-weight: 700;
}

/* ************************************************** */
</style>

