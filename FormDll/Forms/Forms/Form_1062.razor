async void OnYesButtonClickGrid_ITIL_RequestProblem ()
{
       if (SelectedItemGrid_ITIL_RequestProblem != null)
    {
      if (SelectedItemGrid_ITIL_RequestProblem.Id == Guid.Empty)
      {
          var ListEntity = _Entity;
        ListEntity.Remove((Entity.ITIL_RequestProblem)SelectedItemGrid_ITIL_RequestProblem);
     
      }
      else
      {
        var cleanModel = new Entity.ITIL_RequestProblem();
      // چک کن آیا پراپرتی IsDelete در این نوع وجود دارد؟
        var prop = typeof(Entity.ITIL_RequestProblem).GetProperty("IsDelete");
        if (prop != null && prop.CanRead && prop.CanWrite)
        {
            // مقدار فعلی را بگیر
            var currentValue = prop.GetValue(SelectedItemGrid_ITIL_RequestProblem);

            if (currentValue is bool boolValue)
            {
                // مقدار را معکوس کن
                var newValue = !boolValue;

                // روی هر دو شیء تنظیم کن
                prop.SetValue(SelectedItemGrid_ITIL_RequestProblem, newValue);
                prop.SetValue(cleanModel, newValue);
            }
        }
        EntityHelper.SetPropertyValue(cleanModel, cleanModel._GetIdName, SelectedItemGrid_ITIL_RequestProblem._Id);
    
      await PostDataDelete(cleanModel); 
       
      }
    }
    var e= SelectedItemGrid_ITIL_RequestProblem;
    
    Grid_ITIL_RequestProblem.Reload();
    ConfirmationShownITIL_RequestProblem = false;
     await Task.Yield();
    await InvokeAsync(StateHasChanged);

}
void OnNoButtonClickGrid_ITIL_RequestProblem ()
{
    ConfirmationShownITIL_RequestProblem = false;
}

