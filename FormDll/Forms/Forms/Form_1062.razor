            IndexGrid_ITIL_RequestProblem = VisibleIndex + 1;
    Grid_ITIL_RequestProblem.StartEditRowAsync(IndexGrid_ITIL_RequestProblem);
    }
    }
    else if (OpenDialogCodeITIL_RequestProblem == 0)
    {
        if (VisibleIndex != 0)
        {

            Grid_ITIL_RequestProblem.CancelEditAsync();
            IndexGrid_ITIL_RequestProblem = VisibleIndex - 1;
    Grid_ITIL_RequestProblem.StartEditRowAsync(IndexGrid_ITIL_RequestProblem);
    }

    }
    var e = (Entity.ITIL_RequestProblem)Grid_ITIL_RequestProblem.GetDataItem(IndexGrid_ITIL_RequestProblem);
    JsonData = await Utility.JSON.ToJson(e);
    await Task.Delay(300);
    
    StateHasChanged();
    }
