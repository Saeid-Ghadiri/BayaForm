public void SaveGrid_ITIL_RequestProblem(object DataItem, object EditModel)
{
    var ListEntity = _Entity;
    var MainModel = (Entity.ITIL_RequestProblem)DataItem;
    if (MainModel != null)
    {
MainModel.Id = ((Entity.ITIL_RequestProblem)EditModel).Id;
MainModel.RequestID = ((Entity.ITIL_RequestProblem)EditModel).RequestID;
MainModel.CreateUser = ((Entity.ITIL_RequestProblem)EditModel).CreateUser;
MainModel.UpdateUser = ((Entity.ITIL_RequestProblem)EditModel).UpdateUser;
MainModel.CreateDate = ((Entity.ITIL_RequestProblem)EditModel).CreateDate;
MainModel.UpdateDate = ((Entity.ITIL_RequestProblem)EditModel).UpdateDate;
MainModel.IsDelete = ((Entity.ITIL_RequestProblem)EditModel).IsDelete;
MainModel.ProblemName = ((Entity.ITIL_RequestProblem)EditModel).ProblemName;
MainModel.ParentCode = ((Entity.ITIL_RequestProblem)EditModel).ParentCode;
MainModel.ProblemSolver = ((Entity.ITIL_RequestProblem)EditModel).ProblemSolver;
MainModel.ProblemSolverName = ((Entity.ITIL_RequestProblem)EditModel).ProblemSolverName;
MainModel.ProccessLevel = ((Entity.ITIL_RequestProblem)EditModel).ProccessLevel;
MainModel.ProccessLevelName = ((Entity.ITIL_RequestProblem)EditModel).ProccessLevelName;

    }
    else
    {
    ListEntity.Add((Entity.ITIL_RequestProblem)EditModel);
    }
}

