<style>
    /* ************************************************** */
.detailArea form div:not(.devdrop) {
  margin-top: .1rem;
}

/* ************************************************** */
/* استایل اصلی هدر */
.interview-header {
  background: linear-gradient(135deg, #0f4c81 0%, #1a237e 100%);
  color: white;
  padding: 1.5rem;
  border-radius: 10px 10px 0 0;
  position: relative;
  overflow: hidden;
  box-shadow: 0 5px 20px rgba(15, 76, 129, 0.3);
  margin-bottom: 1.5rem;
}

/* محتوای هدر */
.interview-content {
  display: flex;
  align-items: center;
  position: relative;
  z-index: 3;
  gap: 1.2rem;
}

.interview-icon {
  font-size: 2.2rem;
  color: #ffd600;
  filter: drop-shadow(0 2px 3px rgba(0, 0, 0, 0.3));
  transition: all 0.3s ease;
}

.interview-text h2 {
  font-weight: 600;
  margin-bottom: 0.3rem;
  font-size: 1.4rem;
}

.interview-text p {
  margin: 0;
  opacity: 0.9;
  font-size: 0.85rem;
}

/* عناصر تزئینی */
.interview-decoration {
  position: absolute;
  z-index: 1;
  background: rgba(255, 255, 255, 0.1);
}

.interview-dots {
  width: 100px;
  height: 100px;
  border-radius: 50%;
  top: -30px;
  left: -30px;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.15) 20%, transparent 70%);
}

.interview-ring {
  width: 60px;
  height: 60px;
  border-radius: 50%;
  bottom: -20px;
  right: -20px;
  border: 5px solid rgba(255, 214, 0, 0.2);
  background: transparent;
}

/* انیمیشن‌ها */
@@keyframes swing {
  0% {
    transform: rotate(0deg);
  }

  15% {
    transform: rotate(8deg);
  }

  30% {
    transform: rotate(-6deg);
  }

  45% {
    transform: rotate(4deg);
  }

  60% {
    transform: rotate(-2deg);
  }

  75% {
    transform: rotate(1deg);
  }

  100% {
    transform: rotate(0deg);
  }
}

@@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(5px);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@@keyframes pulse {
  0% {
    transform: scale(0.95);
    opacity: 0.7;
  }

  50% {
    transform: scale(1.05);
    opacity: 0.3;
  }

  100% {
    transform: scale(0.95);
    opacity: 0.7;
  }
}

.swing-animation {
  animation: swing 2s ease-in-out infinite;
}

.fade-animation {
  animation: fadeIn 1.2s ease-out forwards;
}

.pulse-animation {
  animation: pulse 5s ease-in-out infinite;
}

/* افکت‌های تعاملی */
.interview-icon:hover {
  transform: scale(1.1) rotate(10deg);
  color: #ffeb3b;
}

.interview-header:hover .interview-dots {
  transform: translate(5px, 5px);
}
</style>

