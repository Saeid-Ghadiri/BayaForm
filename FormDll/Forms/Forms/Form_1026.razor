async Task ChangePageGrid_SH_Petco_Annarr()
{
    int VisibleIndex = IndexGrid_SH_Petco_Annarr;
    try
    {
    if (OpenDialogCodeSH_Petco_Annarr == 1)
    {
        if (VisibleIndex != (Grid_SH_Petco_Annarr.GetVisibleRowCount() - 1))
    { 
            Grid_SH_Petco_Annarr.CancelEditAsync();
            IndexGrid_SH_Petco_Annarr = VisibleIndex + 1;
    Grid_SH_Petco_Annarr.StartEditRowAsync(IndexGrid_SH_Petco_Annarr);
    }
    }
    else if (OpenDialogCodeSH_Petco_Annarr == 0)
    {
        if (VisibleIndex != 0)
        {

            Grid_SH_Petco_Annarr.CancelEditAsync();
            IndexGrid_SH_Petco_Annarr = VisibleIndex - 1;
    Grid_SH_Petco_Annarr.StartEditRowAsync(IndexGrid_SH_Petco_Annarr);
    }

    }
    var e = (Entity.SH_Petco_Annarr)Grid_SH_Petco_Annarr.GetDataItem(IndexGrid_SH_Petco_Annarr);
    JsonData = await Utility.JSON.ToJson(e);
    await Task.Delay(300);
    
    StateHasChanged();
    }
    catch (Exception ex)
    {

    Console.WriteLine("error in ChagePage" + ex.Message);
