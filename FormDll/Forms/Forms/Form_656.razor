async void Dialog_Grid_HR_ORG_Sections(int _OpenDialogCode, int VisibleIndex, GridEditFormTemplateContext e)
{
    OpenDialogCodeHR_ORG_Sections = _OpenDialogCode;
    if (!CheckChangedData(await Utility.JSON.ToJson(e.EditModel)))
    {
    _ContextFormTemplateHR_ORG_Sections = e;
    ConfirmationHR_ORG_Sections = true;
    }
    else
    {
    await OnNoButtonHR_ORG_Sections();
    }
}
async Task OnYesButtonHR_ORG_Sections()
{

    ConfirmationHR_ORG_Sections = false;
    await Task.Delay(1500);
    //bool FormValidate = await JSO.InvokeAsync<bool>("submitForm");
    bool FormValidate =  await JS.InvokeAsync<bool>("submitForm");
    if (FormValidate)
    {
        bool NotValid = false;
    var e = _ContextFormTemplateHR_ORG_Sections.EditModel;
         //events
         

        if (!NotValid)
         {
        SaveGrid_HR_ORG_Sections(_ContextFormTemplateHR_ORG_Sections.DataItem, _ContextFormTemplateHR_ORG_Sections.EditModel);
            await Grid_HR_ORG_Sections.CancelEditAsync();
         await ChangePageGrid_HR_ORG_Sections();
         await SetEditFormContextGrid_HR_ORG_Sections();
         }
          
    }

}
async Task OnNoButtonHR_ORG_Sections()
{
    ConfirmationHR_ORG_Sections = false;
    await ChangePageGrid_HR_ORG_Sections();
    await SetEditFormContextGrid_HR_ORG_Sections();

}
async Task SetEditFormContextGrid_HR_ORG_Sections()
{
    var e = (Entity.HR_ORG_Sections)Grid_HR_ORG_Sections.GetDataItem(IndexGrid_HR_ORG_Sections);
    JsonData = await Utility.JSON.ToJson(e);
}

async Task ChangePageGrid_HR_ORG_Sections()
{
    int VisibleIndex = IndexGrid_HR_ORG_Sections;
    try
    {
    if (OpenDialogCodeHR_ORG_Sections == 1)
    {
        if (VisibleIndex != (Grid_HR_ORG_Sections.GetVisibleRowCount() - 1))
    { 
            Grid_HR_ORG_Sections.CancelEditAsync();
            IndexGrid_HR_ORG_Sections = VisibleIndex + 1;
    Grid_HR_ORG_Sections.StartEditRowAsync(IndexGrid_HR_ORG_Sections);
    }
    }
    else if (OpenDialogCodeHR_ORG_Sections == 0)
    {
        if (VisibleIndex != 0)
        {

            Grid_HR_ORG_Sections.CancelEditAsync();
            IndexGrid_HR_ORG_Sections = VisibleIndex - 1;
    Grid_HR_ORG_Sections.StartEditRowAsync(IndexGrid_HR_ORG_Sections);
    }

    }
    var e = (Entity.HR_ORG_Sections)Grid_HR_ORG_Sections.GetDataItem(IndexGrid_HR_ORG_Sections);
    JsonData = await Utility.JSON.ToJson(e);
    await Task.Delay(300);
    
    StateHasChanged();
    }
    catch (Exception ex)
    {

    Console.WriteLine("error in ChagePage" + ex.Message);
    }

}

