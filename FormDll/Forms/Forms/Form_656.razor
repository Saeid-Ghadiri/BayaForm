{
    //تعداد سطرهای کل
_VisibleIndex = Grid_HR_ORG_Sections.GetVisibleRowCount();
setFocusOff();
IsNew = true;
await ShowFormCU(null);
var e = new Entity.HR_ORG_Sections();
await Task.Delay(300);

}

async Task StartModalGrid_HR_ORG_Sections(GridCommandColumnCellDisplayTemplateContext Context)
{
    IsNew = false;
setFocusOn();
