    /// </summary>
    /// <param name="e"></param>
    public async Task ShowFormCU(object e)
    {
        await InvokeAsync(StateHasChanged);
        await Task.Yield();
        object Id = null;
        Type type = null;
        ShowForm = true;
        await InvokeAsync(StateHasChanged);
        await Task.Yield();
        if (!IsNew)
        {
            var newRow = (Entity.HR_ORG_Sections)e;
    Id = newRow._Id;
            await InvokeAsync(StateHasChanged);
            await Task.Yield();
        }
        else
        {
            var newRow = new Entity.HR_ORG_Sections();
    Id = newRow._Id;
        }
        await InvokeAsync(StateHasChanged);
        await Task.Yield();
        await GetDataForm(Id);
    }
    /// <summary>
    /// خاموش کردن فوکوس گرید
    /// </summary>
    /// <returns></returns>
    public async Task setFocusOff()
    {
        //اگر فوکوس روشن بود خاموشش کن
        if (Grid_HR_ORG_Sections.FocusedRowEnabled)
    {
            //به علت یروزرسانی دیتاگرید و اینکه فوکوس باید مقدار اولیه داده شود از خط زیر استفاده می شود
            Grid_HR_ORG_Sections.BeginUpdate();
    Grid_HR_ORG_Sections.FocusedRowEnabled = false;
    Grid_HR_ORG_Sections.EndUpdate();
    }

    }
    /// <summary>
    /// فعال کردن فوکوس گرید
    /// </summary>
    /// <returns></returns>
    public async Task setFocusOn()
    {
        if (!Grid_HR_ORG_Sections.FocusedRowEnabled)
    {
            Grid_HR_ORG_Sections.BeginUpdate();
    Grid_HR_ORG_Sections.FocusedRowEnabled = true;

    Grid_HR_ORG_Sections.EndUpdate();
    }

    }

    public async Task SelectRecord(int PageIndex, int __VisibleIndex)
    {

        isSending = true;
        await setFocusOn();
        PageIndexChanged(PageIndex);
        await ShowFormCU(Grid_HR_ORG_Sections.GetDataItem(__VisibleIndex));
    DxPager.ActivePageIndex = PageIndex;
        Grid_HR_ORG_Sections.BeginUpdate();
    Grid_HR_ORG_Sections.PageIndex = PageIndex;
    Grid_HR_ORG_Sections.EndUpdate();
    Grid_HR_ORG_Sections.SetFocusedRowIndex(__VisibleIndex);

    isSending = false;
    }

