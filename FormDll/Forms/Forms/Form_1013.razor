    /// <summary>
    /// نمایش دادن فرم CU برای ویرایش و ضافه کردن رکورد
    /// </summary>
    /// <param name="e"></param>
    public async Task ShowFormCU(object e)
    {
        await InvokeAsync(StateHasChanged);
        await Task.Yield();
        object Id = null;
        Type type = null;
        ShowForm = true;
        await InvokeAsync(StateHasChanged);
        await Task.Yield();
        if (!IsNew)
        {
            var newRow = (Entity.HR_CRS_ExtensionPersonnelContract)e;
    Id = newRow._Id;
            await InvokeAsync(StateHasChanged);
            await Task.Yield();
        }
        else
        {
            var newRow = new Entity.HR_CRS_ExtensionPersonnelContract();
    Id = newRow._Id;
        }
        await InvokeAsync(StateHasChanged);
        await Task.Yield();
        await GetDataForm(Id);
    }
    /// <summary>
    /// خاموش کردن فوکوس گرید
    /// </summary>
    /// <returns></returns>
    public async Task setFocusOff()
    {
        //اگر فوکوس روشن بود خاموشش کن
        if (Grid_HR_CRS_ExtensionPersonnelContract.FocusedRowEnabled)
    {
            //به علت یروزرسانی دیتاگرید و اینکه فوکوس باید مقدار اولیه داده شود از خط زیر استفاده می شود
            Grid_HR_CRS_ExtensionPersonnelContract.BeginUpdate();
    Grid_HR_CRS_ExtensionPersonnelContract.FocusedRowEnabled = false;
    Grid_HR_CRS_ExtensionPersonnelContract.EndUpdate();
    }

    }
    /// <summary>
    /// فعال کردن فوکوس گرید
    /// </summary>
    /// <returns></returns>
    public async Task setFocusOn()
    {
        if (!Grid_HR_CRS_ExtensionPersonnelContract.FocusedRowEnabled)
    {
            Grid_HR_CRS_ExtensionPersonnelContract.BeginUpdate();
    Grid_HR_CRS_ExtensionPersonnelContract.FocusedRowEnabled = true;

    Grid_HR_CRS_ExtensionPersonnelContract.EndUpdate();
    }

    }

    public async Task SelectRecord(int PageIndex, int __VisibleIndex)
    {

        isSending = true;
        await setFocusOn();
        PageIndexChanged(PageIndex);
        await ShowFormCU(Grid_HR_CRS_ExtensionPersonnelContract.GetDataItem(__VisibleIndex));
    DxPager.ActivePageIndex = PageIndex;
        Grid_HR_CRS_ExtensionPersonnelContract.BeginUpdate();
    Grid_HR_CRS_ExtensionPersonnelContract.PageIndex = PageIndex;
    Grid_HR_CRS_ExtensionPersonnelContract.EndUpdate();
    Grid_HR_CRS_ExtensionPersonnelContract.SetFocusedRowIndex(__VisibleIndex);

    isSending = false;
    }

    public async Task SetPageIndex(int Index)
    {
        PageIndex = Index;
        Grid_HR_CRS_ExtensionPersonnelContract.BeginUpdate();
    Grid_HR_CRS_ExtensionPersonnelContract.PageIndex = Index;
    Grid_HR_CRS_ExtensionPersonnelContract.EndUpdate();
    }
    /// <summary>
    /// ارسال داده
    /// </summary>
    /// <returns></returns>
    private async Task<bool> PostDataDelete(Entity.HR_CRS_ExtensionPersonnelContract _entity)
    {
        string Data = await Utility.JSON.ToJson(_entity);

        var TablePost = new Table();
        TablePost.Name = "HR_CRS_ExtensionPersonnelContract";
        TablePost.Column = new List<Coulmn>
                    {
                    new Coulmn {Name=_entity._GetIdName  , NameAs= _entity._GetIdName},
                    new Coulmn {Name ="IsDelete",NameAs="IsDelete" }

                    };
        bool IsOk = false;
        var Model = await ApiServer.External.Services.Data.Put(Data, TablePost.Name, TablePost, null, _User.UserID.ToString());
        if (Model?.Status == HttpStatusCode.OK)
        {
            IsOk = true;
        }

        return IsOk;
    }
