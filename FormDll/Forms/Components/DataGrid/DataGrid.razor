/// <summary>
/// پیدا کردن آیتم در Data بر اساس DropdownValue و component.valueProperty
/// </summary>
private async Task FindItemByDropdownValue()
{
    FoundItem = null;

    // بررسی اینکه DropdownValue و valueProperty موجود باشند
    if (DropdownValue == null || Component == null || string.IsNullOrEmpty(Component.valueProperty))
    {
        return;
    }

    // بررسی اینکه Data موجود باشد
    if (Data == null)
    {
        return;
    }

    try
    {
        // تبدیل Data به لیست
        var dataList = Data as List<object>;
        if (dataList.Count == 0)
        {
            return;
        }

        // تبدیل DropdownValue به string برای مقایسه
        string dropdownValueStr = DropdownValue?.ToString() ?? "";

        // جستجو در لیست Data
        foreach (var item in dataList)
        {
            if (item == null)
                continue;

            // تبدیل آیتم به JObject برای دسترسی به property
            var json = Newtonsoft.Json.JsonConvert.SerializeObject(item);
            JObject data = JObject.Parse(json);

            // دریافت مقدار فیلد valueProperty
            var fieldValue = data[Component.valueProperty];
            if (fieldValue != null)
            {
                string fieldValueStr = fieldValue.ToString();

                // مقایسه با DropdownValue
                if (fieldValueStr == dropdownValueStr)
                {
                    FoundItem = item;
                    break;
                }
            }
        }
        if (FoundItem != null)
        {
            DxGrid.SelectDataItem(FoundItem);
        }
    }
    catch (Exception ex)
    {
        Console.WriteLine("#Log FindItemByDropdownValue Error: " + ex.Message);
    }
}

