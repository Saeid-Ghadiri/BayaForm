            var template = Component.template;
            template = template.Replace("<span>", "");
            template = template.Replace("</span>", "");
            template = template.Replace("item.", "");
            template = template.Replace("&#160;", "");
            template = template.Trim();
            var List = template.Split(" ").ToList();


            //List = List.Select(x => x.Replace("{{", "").Replace("}}", "")).ToList();
            List<KeyValuePair<string, string>> list =  ConvertParameter.GetTemplate(Component.template).Result;

            foreach (var item in list)
            {
                //عنوان رو نشون بدیم
                //ListColumn.Add(new View_values() { key = "PriorityTitle", label = "عنوان" });
                 ListColumn.Add(new View_values() { key = item.Key, label = item.Value });
            }

            string Url = Component.data.url;
            if (!Url.Contains("?"))
            { Url += "?"; }
            else
            { Url += "&"; }



            //todo فیلتر
            //Global_CountryId={{data.Global_CountryId}}
            //splite =

            var QueryString = Url.Split("?")[1];
            var ListQueryString = QueryString.Split("=");

            foreach (var item in ListQueryString)
            { 
                if (item.Contains("{{"))
                {//اگه پارامتر داشت
                    //حذف کاراکتر های اضافه
                    string KeyName = item.Replace("&", "").Replace("{", "").Replace("}", "");
                    //بیایم پارامتر رو بگیریم و مقدارشو از موجودیت یا رکورد گرید بگیریم

                    //data.Global_CountryId
                    //data.Global_CountryId.Id
                    //row.Global_CountryId
                    //row.Global_CountryId.Id

                    //_Entity
                    if (KeyName.StartsWith("data."))
                    {//موجودیت اصلی
                        KeyName = KeyName.Replace("data.", "");

                        string Value = await GetValueFromObject(__Entity, KeyName);
                        //جایگزینی مقدار داخل ادرس
                        Url = Url.Replace("{{data." + KeyName + "}}", Value);
                    }

                    //_EntityRow
                    if (KeyName.StartsWith("row."))
                    {//موجودیت گرید ایتیم گرید
                        KeyName = KeyName.Replace("row.", "");

                        string Value = await GetValueFromObject(_EntityRow, KeyName);
                        //جایگزینی مقدار داخل ادرس
                        Url = Url.Replace("{{row." + KeyName + "}}", Value);
                    }
                }
            }



            Url += "limit=" + PageSize + "&skip=" + skip;


            if (_currentFilter != null)
            {//اگه فیلتر کوئری بیلدر ارسال شده استفاده کن
