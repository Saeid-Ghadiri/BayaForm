    /// <summary>
    /// دریافت مقدار یک فیلد از موجودیت
    /// </summary>
    /// <param name="Entity">ابجکت موجودیت</param>
    /// <param name="KeyName">اسم فیلدی که میخوایم مقدارشو بگیریم</param>
    /// <returns></returns>
    public async Task<string> GetValueFromObject(object Entity, string KeyName)
    {
        if (Entity == null)
        {//موجودیت داده شده نال بود خالی برگردون
            return "";
        } 
        if (KeyName.Contains("."))
        {//وقتی اسم موجودیت در موجودیت هستش
         //اگه چند اسمی بودش
         //Global_CountryId.Id
         //todo
            string newKeyName = "";
            object newEntity = null; 
            return await GetValueFromObject(newEntity, newKeyName);
        } 
        var type = Entity.GetType();
        string Value = "";

        var FindedProperty = type.GetProperties().FirstOrDefault(x => x.Name == KeyName);
        if (FindedProperty != null)
        {//فیلد رو پیدا کرد
            var FindedValue = FindedProperty.GetValue(Entity);

            if (FindedValue != null)
            {//مقدارش نال نبود
                Value = FindedValue.ToString();
            }
        }

        return Value;
    }
